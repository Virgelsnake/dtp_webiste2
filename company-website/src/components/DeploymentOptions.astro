---

<section class="py-20 sm:py-32">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Build where it suits your organisation</h2>
    </div>
    <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- Cloud Card -->
      <div class="bento-card group">
        <div class="flex justify-center mb-8">
          <div class="relative">
            <!-- Animated outer ring -->
            <div class="w-24 h-24 rounded-full border-2 border-blue-500/30 group-hover:animate-spin-slow"></div>
            <!-- Glowing middle ring -->
            <div class="absolute inset-2 w-20 h-20 rounded-full border border-blue-400/50 group-hover:animate-pulse"></div>
            <!-- Inner circle with icon -->
            <div class="absolute inset-4 w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center border border-blue-500/40">
              <svg class="w-8 h-8 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M3,7H9V5H3V7M3,13H9V11H3V13M3,19H9V17H3V19M11,7H21V5H11V7M11,13H21V11H11V13M11,19H21V17H11V19Z"/>
              </svg>
            </div>
            <!-- Glowing effect -->
            <div class="absolute inset-0 w-24 h-24 rounded-full bg-blue-500/10 group-hover:animate-ping"></div>
          </div>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4 text-center">Cloud (Managed by us)</h3>
        <p class="text-gray-300 mb-6 text-center">Fast to start, managed updates, and minimal overhead.</p>
        <div class="text-center">
          <a href="#" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
            Discuss Cloud option
          </a>
        </div>
      </div>

      <!-- Dedicated Card -->
      <div class="bento-card group">
        <div class="flex justify-center mb-8">
          <div class="relative">
            <!-- Animated outer ring -->
            <div class="w-24 h-24 rounded-full border-2 border-green-500/30 group-hover:animate-spin-slow"></div>
            <!-- Glowing middle ring -->
            <div class="absolute inset-2 w-20 h-20 rounded-full border border-green-400/50 group-hover:animate-pulse"></div>
            <!-- Inner circle with icon -->
            <div class="absolute inset-4 w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center border border-green-500/40">
              <svg class="w-8 h-8 text-green-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,7C13.4,7 14.8,8.6 14.8,10V11.5C15.4,11.5 16,12.1 16,12.7V16.2C16,16.8 15.4,17.3 14.8,17.3H9.2C8.6,17.3 8,16.8 8,16.2V12.7C8,12.1 8.6,11.5 9.2,11.5V10C9.2,8.6 10.6,7 12,7M12,8.2C11.2,8.2 10.5,8.7 10.5,10V11.5H13.5V10C13.5,8.7 12.8,8.2 12,8.2Z"/>
              </svg>
            </div>
            <!-- Glowing effect -->
            <div class="absolute inset-0 w-24 h-24 rounded-full bg-green-500/10 group-hover:animate-ping"></div>
          </div>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4 text-center">Dedicated (Single-tenant)</h3>
        <p class="text-gray-300 mb-6 text-center">Your own isolated environment for stronger control and performance.</p>
        <div class="text-center">
          <a href="#" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
            Discuss Dedicated option
          </a>
        </div>
      </div>

      <!-- Self-Hosted Card -->
      <div class="bento-card group">
        <div class="flex justify-center mb-8">
          <div class="relative">
            <!-- Animated outer ring -->
            <div class="w-24 h-24 rounded-full border-2 border-purple-500/30 group-hover:animate-spin-slow"></div>
            <!-- Glowing middle ring -->
            <div class="absolute inset-2 w-20 h-20 rounded-full border border-purple-400/50 group-hover:animate-pulse"></div>
            <!-- Inner circle with icon -->
            <div class="absolute inset-4 w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center border border-purple-500/40">
              <svg class="w-8 h-8 text-purple-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M4,1C2.89,1 2,1.89 2,3V7C2,8.11 2.89,9 4,9H1V11H13V9H10C11.11,9 12,8.11 12,7V3C12,1.89 11.11,1 10,1H4M4,3H10V7H4V3M3,13V18L3,19H21V18V13H3M5,15H19V17H5V15Z"/>
              </svg>
            </div>
            <!-- Glowing effect -->
            <div class="absolute inset-0 w-24 h-24 rounded-full bg-purple-500/10 group-hover:animate-ping"></div>
          </div>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4 text-center">Self-Hosted (On your stack)</h3>
        <p class="text-gray-300 mb-6 text-center">Full control within your environment and policies.</p>
        <div class="text-center">
          <a href="#" class="inline-flex items-center px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
            Discuss Self-Hosted option
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bento-card {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
    border-radius: 1.5rem;
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .bento-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 20%, rgba(59, 130, 246, 0.15), transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .bento-card:hover {
    transform: translateY(-8px);
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 25px 50px -12px rgba(59, 130, 246, 0.25), 0 20px 25px -5px rgba(0, 0, 0, 0.4);
  }

  .bento-card:hover::before {
    opacity: 1;
  }

  /* Icon animation styles */
  .bento-card .w-24.h-24.rounded-full.border-2 {
    transition: transform 0.3s ease;
  }

  .bento-card:hover .w-24.h-24.rounded-full.border-2 {
    animation: spin-slow 8s linear infinite;
  }

  .bento-card .absolute.inset-2.w-20.h-20.rounded-full.border {
    transition: opacity 0.3s ease;
  }

  .bento-card:hover .absolute.inset-2.w-20.h-20.rounded-full.border {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .bento-card .absolute.inset-0.w-24.h-24.rounded-full {
    transition: opacity 0.3s ease;
  }

  .bento-card:hover .absolute.inset-0.w-24.h-24.rounded-full {
    animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  
  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }
</style>
