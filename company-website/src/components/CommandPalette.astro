---
// Command Palette Component - S10
// Cmd+K search overlay for pages, FAQ, and case studies
---

<div id="command-palette" class="cmd-palette" role="dialog" aria-modal="true" aria-label="Site search">
  <div class="cmd-palette-overlay"></div>
  <div class="cmd-palette-container">
    <div class="cmd-palette-header">
      <svg class="cmd-search-icon" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
      </svg>
      <input 
        type="search" 
        id="cmd-input" 
        class="cmd-input" 
        placeholder="Search pages, FAQ, case studies..."
        autocomplete="off"
        spellcheck="false"
      />
      <button class="cmd-close" id="cmd-close" aria-label="Close search">
        <svg viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
    <div class="cmd-shortcut-hint">
      <span>Press <kbd>↑</kbd> <kbd>↓</kbd> to navigate, <kbd>Enter</kbd> to select, <kbd>Esc</kbd> to close</span>
    </div>
    <div id="cmd-results" class="cmd-results"></div>
  </div>
</div>

<script>
  // Search data - pages, FAQ questions, case studies
  const searchData = [
    // Pages
    { title: 'Home', url: '/', type: 'page' },
    { title: 'Our Approach / Services', url: '/services', type: 'page' },
    { title: 'Case Studies', url: '/case-studies', type: 'page' },
    { title: 'About DTP', url: '/about', type: 'page' },
    { title: 'Contact', url: '/contact', type: 'page' },
    { title: 'FAQ', url: '/faq', type: 'page' },
    
    // FAQ Questions
    { title: 'How long does a typical engagement take?', url: '/faq', type: 'faq' },
    { title: 'Do you work with existing systems?', url: '/faq', type: 'faq' },
    { title: 'How is pricing structured?', url: '/faq', type: 'faq' },
    { title: 'What industries do you specialise in?', url: '/faq', type: 'faq' },
    { title: 'Can we start with a small project?', url: '/faq', type: 'faq' },
    
    // Case Studies
    { title: 'Protective Coating Automation - Manufacturing', url: '/case-studies', type: 'case-study' },
    { title: 'Manufacturing Maintenance AI - Mobile Messaging', url: '/case-studies', type: 'case-study' },
    { title: 'Infrastructure AI Partnership - Technical Subcontracting', url: '/case-studies', type: 'case-study' },
    
    // Use Cases
    { title: 'Operations Automation', url: '/#use-cases', type: 'use-case' },
    { title: 'Data & Reporting', url: '/#use-cases', type: 'use-case' },
    { title: 'AI Assistants for Teams', url: '/#use-cases', type: 'use-case' },
    
    // Process
    { title: 'Discovery Phase', url: '/services', type: 'process' },
    { title: 'Proof of Concept', url: '/services', type: 'process' },
    { title: 'MVP Development', url: '/services', type: 'process' },
    { title: 'Pilot Programme', url: '/services', type: 'process' },
    { title: 'Full Launch', url: '/services', type: 'process' },
  ];

  // Simple fuzzy match function
  function fuzzyMatch(query, text) {
    query = query.toLowerCase();
    text = text.toLowerCase();
    
    let score = 0;
    let queryIndex = 0;
    
    for (let i = 0; i < text.length && queryIndex < query.length; i++) {
      if (text[i] === query[queryIndex]) {
        score++;
        queryIndex++;
      }
    }
    
    // Bonus for exact substring match
    if (text.includes(query)) {
      score += query.length * 2;
    }
    
    // Bonus for starting with query
    if (text.startsWith(query)) {
      score += query.length;
    }
    
    return queryIndex === query.length ? score : 0;
  }

  // Get type icon
  function getTypeIcon(type) {
    const icons = {
      page: '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/></svg>',
      faq: '<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>',
      'case-study': '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>',
      'use-case': '<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg>',
      process: '<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>'
    };
    return icons[type] || icons.page;
  }

  // Get type label
  function getTypeLabel(type) {
    const labels = {
      page: 'Page',
      faq: 'FAQ',
      'case-study': 'Case Study',
      'use-case': 'Use Case',
      process: 'Process'
    };
    return labels[type] || 'Page';
  }

  let selectedIndex = 0;
  let currentResults = [];

  function openPalette() {
    const palette = document.getElementById('command-palette');
    const input = document.getElementById('cmd-input');
    palette.classList.add('active');
    input.focus();
    input.value = '';
    renderResults(searchData.slice(0, 8)); // Show first 8 items by default
  }

  function closePalette() {
    const palette = document.getElementById('command-palette');
    palette.classList.remove('active');
  }

  function renderResults(results) {
    const container = document.getElementById('cmd-results');
    currentResults = results;
    selectedIndex = 0;
    
    if (results.length === 0) {
      container.innerHTML = '<div class="cmd-no-results">No results found</div>';
      return;
    }
    
    container.innerHTML = results.map((item, index) => `
      <a 
        href="${item.url}" 
        class="cmd-result ${index === 0 ? 'selected' : ''}" 
        data-index="${index}"
      >
        <span class="cmd-result-icon">${getTypeIcon(item.type)}</span>
        <div class="cmd-result-content">
          <span class="cmd-result-title">${item.title}</span>
          <span class="cmd-result-type">${getTypeLabel(item.type)}</span>
        </div>
        <span class="cmd-result-arrow">→</span>
      </a>
    `).join('');
  }

  function updateSelection() {
    const items = document.querySelectorAll('.cmd-result');
    items.forEach((item, index) => {
      item.classList.toggle('selected', index === selectedIndex);
    });
    
    // Scroll selected into view
    const selected = items[selectedIndex];
    if (selected) {
      selected.scrollIntoView({ block: 'nearest' });
    }
  }

  function performSearch(query) {
    if (!query.trim()) {
      renderResults(searchData.slice(0, 8));
      return;
    }
    
    const scored = searchData.map(item => ({
      ...item,
      score: fuzzyMatch(query, item.title)
    })).filter(item => item.score > 0);
    
    scored.sort((a, b) => b.score - a.score);
    renderResults(scored.slice(0, 10));
  }

  // Event listeners
  document.addEventListener('keydown', (e) => {
    // Cmd+K or Ctrl+K to open
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openPalette();
    }
    
    // Esc to close
    if (e.key === 'Escape') {
      closePalette();
    }
    
    // Only handle navigation when palette is open
    const palette = document.getElementById('command-palette');
    if (!palette.classList.contains('active')) return;
    
    // Arrow navigation
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIndex = Math.min(selectedIndex + 1, currentResults.length - 1);
      updateSelection();
    }
    
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIndex = Math.max(selectedIndex - 1, 0);
      updateSelection();
    }
    
    // Enter to navigate
    if (e.key === 'Enter' && currentResults[selectedIndex]) {
      window.location.href = currentResults[selectedIndex].url;
    }
  });

  // Input handling
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('cmd-input');
    const closeBtn = document.getElementById('cmd-close');
    const overlay = document.querySelector('.cmd-palette-overlay');
    
    if (input) {
      input.addEventListener('input', (e) => {
        performSearch(e.target.value);
      });
    }
    
    if (closeBtn) {
      closeBtn.addEventListener('click', closePalette);
    }
    
    if (overlay) {
      overlay.addEventListener('click', closePalette);
    }
    
    // Click on results
    document.addEventListener('click', (e) => {
      const result = e.target.closest('.cmd-result');
      if (result) {
        const index = parseInt(result.dataset.index);
        if (currentResults[index]) {
          window.location.href = currentResults[index].url;
        }
      }
    });
  });
</script>

<style>
  .cmd-palette {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
    opacity: 0;
    visibility: hidden;
    transition: opacity 200ms ease, visibility 200ms ease;
  }

  .cmd-palette.active {
    opacity: 1;
    visibility: visible;
  }

  .cmd-palette-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .cmd-palette-container {
    position: relative;
    width: 100%;
    max-width: 640px;
    margin: 0 1rem;
    background: var(--ma-surface);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }

  .cmd-palette-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--ma-border);
  }

  .cmd-search-icon {
    width: 20px;
    height: 20px;
    color: var(--ma-text-dim);
    flex-shrink: 0;
  }

  .cmd-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--ma-white);
    font-size: 1rem;
    outline: none;
    padding: 0;
  }

  .cmd-input::placeholder {
    color: var(--ma-text-dim);
  }

  .cmd-close {
    width: 44px; /* WCAG touch target minimum */
    height: 44px; /* WCAG touch target minimum */
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--ma-border);
    border-radius: 6px;
    color: var(--ma-text-dim);
    cursor: pointer;
    transition: all 200ms ease;
    flex-shrink: 0;
  }

  .cmd-close:hover {
    border-color: var(--ma-mint);
    color: var(--ma-mint);
  }

  .cmd-close svg {
    width: 16px;
    height: 16px;
  }

  .cmd-shortcut-hint {
    padding: 0.5rem 1.25rem;
    font-size: 0.7rem;
    color: var(--ma-text-dim);
    border-bottom: 1px solid var(--ma-border);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cmd-shortcut-hint kbd {
    background: var(--ma-surface-alt);
    border: 1px solid var(--ma-border);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    font-family: var(--ma-font-mono);
    font-size: 0.65rem;
  }

  .cmd-results {
    max-height: 400px;
    overflow-y: auto;
  }

  .cmd-result {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    text-decoration: none;
    color: var(--ma-text);
    transition: all 150ms ease;
    border-bottom: 1px solid var(--ma-border);
  }

  .cmd-result:last-child {
    border-bottom: none;
  }

  .cmd-result:hover,
  .cmd-result.selected {
    background: rgba(0, 229, 160, 0.08);
  }

  .cmd-result.selected {
    border-left: 3px solid var(--ma-mint);
    padding-left: calc(1.25rem - 3px);
  }

  .cmd-result-icon {
    width: 20px;
    height: 20px;
    color: var(--ma-mint);
    opacity: 0.7;
    flex-shrink: 0;
  }

  .cmd-result-icon svg {
    width: 100%;
    height: 100%;
  }

  .cmd-result-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .cmd-result-title {
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cmd-result-type {
    font-size: 0.7rem;
    color: var(--ma-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cmd-result-arrow {
    color: var(--ma-text-dim);
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 150ms ease;
  }

  .cmd-result:hover .cmd-result-arrow,
  .cmd-result.selected .cmd-result-arrow {
    opacity: 1;
  }

  .cmd-no-results {
    padding: 2rem;
    text-align: center;
    color: var(--ma-text-dim);
    font-size: 0.9rem;
  }

  /* Scrollbar styling */
  .cmd-results::-webkit-scrollbar {
    width: 8px;
  }

  .cmd-results::-webkit-scrollbar-track {
    background: transparent;
  }

  .cmd-results::-webkit-scrollbar-thumb {
    background: var(--ma-border);
    border-radius: 4px;
  }

  .cmd-results::-webkit-scrollbar-thumb:hover {
    background: var(--ma-text-dim);
  }

  /* Mobile optimization for CommandPalette */
  @media (max-width: 640px) {
    .cmd-palette {
      padding-top: 5vh; /* Less top padding on mobile */
    }

    .cmd-palette-container {
      margin: 0 0.5rem;
      max-height: 70vh; /* Prevent keyboard overlap */
    }

    .cmd-palette-header {
      padding: 0.875rem 1rem;
    }

    .cmd-results {
      max-height: 50vh;
    }

    .cmd-result {
      padding: 1rem;
    }

    .cmd-shortcut-hint {
      display: none; /* Hide keyboard hints on mobile */
    }
  }
</style>
