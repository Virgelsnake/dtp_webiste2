---
// Block I - Long phase cards component
const phases = [
  {
    title: "Discovery",
    description: "Define the problem, users, data, and success measures. Leave with a simple plan.",
    deliverables: "scope summary, success metrics, delivery plan.",
    buttonText: "Start with Discovery",
    color: "yellow"
  },
  {
    title: "Proof of Concept (PoC)",
    description: "Test the core idea quickly to prove feasibility and value.",
    deliverables: "working prototype, findings, go/no-go decision.",
    buttonText: "Plan a PoC",
    color: "green"
  },
  {
    title: "Minimum Viable Product (MVP)",
    description: "Build essential features for day-to-day use and learning.",
    deliverables: "usable product, training, next-step roadmap.",
    buttonText: "Build an MVP",
    color: "blue"
  },
  {
    title: "Pilot Programme",
    description: "Run with a small group, measure impact, and refine before wider rollout.",
    deliverables: "pilot results, improvements, launch plan.",
    buttonText: "Run a Pilot",
    color: "purple"
  }
];

const getColorClasses = (color: string) => {
  const colors = {
    yellow: {
      border: 'border-yellow-500/30',
      button: 'bg-yellow-600 hover:bg-yellow-700'
    },
    green: {
      border: 'border-green-500/30',
      button: 'bg-green-600 hover:bg-green-700'
    },
    blue: {
      border: 'border-blue-500/30',
      button: 'bg-blue-600 hover:bg-blue-700'
    },
    purple: {
      border: 'border-purple-500/30',
      button: 'bg-purple-600 hover:bg-purple-700'
    }
  };
  return colors[color as keyof typeof colors] || colors.blue;
};
---

<section class="py-20 sm:py-32 bg-gray-900">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">What you get at each stage</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-6xl mx-auto">
      {phases.map((phase) => {
        const colorClasses = getColorClasses(phase.color);
        return (
          <div class={`phase-card group border ${colorClasses.border}`}>
            <div class="p-8">
              <h3 class="text-2xl font-bold text-white mb-4">{phase.title}</h3>
              <p class="text-gray-300 mb-6 leading-relaxed">{phase.description}</p>
              <div class="mb-6">
                <p class="text-sm font-semibold text-gray-400 mb-2">What you get:</p>
                <p class="text-gray-300">{phase.deliverables}</p>
              </div>
              <div class="text-center">
                <a href="#" class={`inline-flex items-center px-6 py-3 text-white rounded-lg transition-colors font-semibold ${colorClasses.button}`}>
                  {phase.buttonText}
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .phase-card {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .phase-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 20%, rgba(59, 130, 246, 0.15), transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .phase-card:hover {
    transform: translateY(-8px);
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 25px 50px -12px rgba(59, 130, 246, 0.25), 0 20px 25px -5px rgba(0, 0, 0, 0.4);
  }

  .phase-card:hover::before {
    opacity: 1;
  }
</style>
