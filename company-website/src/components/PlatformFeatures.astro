<section class="py-20 sm:py-32 bg-gray-900">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Why organisations work with us</h2>
    </div>
    <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      <div class="bento-section">
        <div class="bento-body">
          <h3 class="text-xl font-semibold text-white">Reduced Risk</h3>
          <p class="mt-4 text-gray-300">We deliver in stages. You see progress early and avoid big-bang surprises.</p>
        </div>
      </div>
      <div class="bento-section">
        <div class="bento-body">
          <h3 class="text-xl font-semibold text-white">Security by Design</h3>
          <p class="mt-4 text-gray-300">Data protection and access controls are built in from day one.</p>
        </div>
      </div>
      <div class="bento-section">
        <div class="bento-body">
          <h3 class="text-xl font-semibold text-white">Reliable Delivery</h3>
          <p class="mt-4 text-gray-300">Clear scope, fixed steps, and regular check-ins keep work on track.</p>
        </div>
      </div>
      <div class="bento-section">
        <div class="bento-body">
          <h3 class="text-xl font-semibold text-white">Scales with You</h3>
          <p class="mt-4 text-gray-300">Start small, prove value, then roll out without rework.</p>
        </div>
      </div>
      <div class="bento-section">
        <div class="bento-body">
          <h3 class="text-xl font-semibold text-white">Flexible Engagement</h3>
          <p class="mt-4 text-gray-300">On your stack, in our cloud, or a hybrid — whatever fits policy and cost.</p>
        </div>
      </div>
      <div class="bento-section">
        <div class="bento-body">
          <h3 class="text-xl font-semibold text-white">Works With Your Tools</h3>
          <p class="mt-4 text-gray-300">We integrate with common meeting, messaging, and project platforms to cut friction.</p>
        </div>
      </div>
    </div>
    <div class="text-center mt-12">
      <a href="#" class="inline-flex items-center text-blue-400 hover:text-blue-300 font-medium">
        See examples of outcomes
      </a>
    </div>
  </div>
</section>

<style>
  .bento-section {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
    border-radius: 1.5rem;
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .bento-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 20%, rgba(59, 130, 246, 0.15), transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .bento-section:hover {
    transform: translateY(-8px);
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 25px 50px -12px rgba(59, 130, 246, 0.25), 0 20px 25px -5px rgba(0, 0, 0, 0.4);
  }

  .bento-section:hover::before {
    opacity: 1;
  }

  .bento-body {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
</style>
