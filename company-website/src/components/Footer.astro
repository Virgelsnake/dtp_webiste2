---
// Footer component - ready for designer styling
---

<footer class="bg-gray-900 text-gray-400">
  <div class="container mx-auto px-6 py-12">
    
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center text-sm">
      <p>&copy; 2025 Digital Technology Partner. All Rights Reserved.</p>
      <div class="flex items-center gap-3 mt-4 md:mt-0">
        <a
          href="#"
          aria-label="X (Twitter)"
          class="social-link relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-slate-800/30 text-blue-400 transition duration-300 hover:text-blue-300 hover:shadow-[0_0_0_1px_rgba(147,197,253,.35),0_10px_24px_-6px_rgba(37,99,235,.45)] before:absolute before:inset-0 before:rounded-lg before:bg-gradient-to-br before:from-blue-500/0 before:to-blue-400/0 before:transition before:duration-300 hover:before:from-blue-500/10 hover:before:to-blue-400/10"
        >
          <svg class="h-6 w-6 social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2H21l-6.5 7.5L22 22h-6.75l-4.25-5.5L5.5 22H3l7.25-8.375L2 2h6.75l4 5.25L18.244 2z"></path>
          </svg>
        </a>

        <a
          href="https://www.linkedin.com/company/dtp-ai/?viewAsMember=true"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="social-link relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-slate-800/30 text-blue-400 transition duration-300 hover:text-blue-300 hover:shadow-[0_0_0_1px_rgba(147,197,253,.35),0_10px_24px_-6px_rgba(37,99,235,.45)] before:absolute before:inset-0 before:rounded-lg before:bg-gradient-to-br before:from-blue-500/0 before:to-blue-400/0 before:transition before:duration-300 hover:before:from-blue-500/10 hover:before:to-blue-400/10"
        >
          <svg class="h-6 w-6 social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM0 8.25h5V23H0V8.25zM8 8.25h4.78v2.01h.07c.66-1.24 2.29-2.55 4.72-2.55 5.05 0 5.98 3.32 5.98 7.63V23h-5v-6.55c0-1.56-.03-3.57-2.18-3.57-2.18 0-2.52 1.7-2.52 3.46V23H8V8.25z"/>
          </svg>
        </a>

        <a
          href="#"
          aria-label="Facebook"
          class="social-link relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-slate-800/30 text-blue-400 transition duration-300 hover:text-blue-300 hover:shadow-[0_0_0_1px_rgba(147,197,253,.35),0_10px_24px_-6px_rgba(37,99,235,.45)] before:absolute before:inset-0 before:rounded-lg before:bg-gradient-to-br before:from-blue-500/0 before:to-blue-400/0 before:transition before:duration-300 hover:before:from-blue-500/10 hover:before:to-blue-400/10"
        >
          <svg class="h-6 w-6 social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .social-icon {
    transition: transform 0.2s ease-in-out;
  }

  /* Nudge icons for perfect visual centering */
  a[aria-label="X (Twitter)"] .social-icon {
    transform: translate(0.5px, 1px) scale(1);
  }
  a[aria-label="LinkedIn"] .social-icon {
     transform: translateY(1px) scale(1);
  }
  a[aria-label="Facebook"] .social-icon {
    transform: translate(-0.5px, 0.5px) scale(1);
  }

  /* Combine hover scale with nudge to prevent override */
  a[aria-label="X (Twitter)"]:hover .social-icon {
    transform: translate(0.5px, 1px) scale(1.1);
  }
  a[aria-label="LinkedIn"]:hover .social-icon {
     transform: translateY(1px) scale(1.1);
  }
  a[aria-label="Facebook"]:hover .social-icon {
    transform: translate(-0.5px, 0.5px) scale(1.1);
  }
</style>

