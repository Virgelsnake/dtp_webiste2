---
// Footer component - ready for designer styling
---

<footer class="bg-gray-900 text-gray-400">
  <div class="container mx-auto px-6 py-12">
    
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center text-sm">
      <p>&copy; 2025 Digital Technology Partner. All Rights Reserved.</p>
      <div class="flex items-center gap-3 mt-4 md:mt-0">
        <a
          href="#"
          aria-label="X (Twitter)"
          class="social-link relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-slate-800/30 text-blue-400 transition duration-300 hover:text-blue-300 hover:shadow-[0_0_0_1px_rgba(147,197,253,.35),0_10px_24px_-6px_rgba(37,99,235,.45)] before:absolute before:inset-0 before:rounded-lg before:bg-gradient-to-br before:from-blue-500/0 before:to-blue-400/0 before:transition before:duration-300 hover:before:from-blue-500/10 hover:before:to-blue-400/10"
        >
          <svg class="h-5 w-5 social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path>
          </svg>
        </a>

        <a
          href="https://www.linkedin.com/company/dtp-ai/?viewAsMember=true"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="social-link relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-slate-800/30 text-blue-400 transition duration-300 hover:text-blue-300 hover:shadow-[0_0_0_1px_rgba(147,197,253,.35),0_10px_24px_-6px_rgba(37,99,235,.45)] before:absolute before:inset-0 before:rounded-lg before:bg-gradient-to-br before:from-blue-500/0 before:to-blue-400/0 before:transition before:duration-300 hover:before:from-blue-500/10 hover:before:to-blue-400/10"
        >
          <svg class="h-5 w-5 social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
          </svg>
        </a>

        <a
          href="#"
          aria-label="Facebook"
          class="social-link relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-slate-800/30 text-blue-400 transition duration-300 hover:text-blue-300 hover:shadow-[0_0_0_1px_rgba(147,197,253,.35),0_10px_24px_-6px_rgba(37,99,235,.45)] before:absolute before:inset-0 before:rounded-lg before:bg-gradient-to-br before:from-blue-500/0 before:to-blue-400/0 before:transition before:duration-300 hover:before:from-blue-500/10 hover:before:to-blue-400/10"
        >
          <svg class="h-5 w-5 social-icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .social-icon {
    transition: transform 0.2s ease-in-out;
  }

  /* Hover effects for social icons */
  .social-link:hover .social-icon {
    transform: scale(1.1);
  }
</style>

