---
// Minimal FAQ block used on homepage under Use Cases section
---

<section class="py-12 sm:py-16 bg-gray-900">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl text-center mb-8">Quick answers</h2>

      <div class="space-y-4">
        <!-- Q1 -->
        <div class="bg-gray-800/50 border border-gray-700/50 rounded-lg backdrop-blur-sm">
          <button class="w-full px-6 py-5 text-left flex items-center justify-between hover:bg-gray-800/70 transition-colors duration-200 focus:outline-none rounded-lg" onclick="toggleFAQMini('faqm-1')" aria-expanded="false" aria-controls="faqm-1">
            <h3 class="text-base sm:text-lg font-semibold text-white pr-4">How do I get started with AI solutions?</h3>
            <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-200 faqm-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div id="faqm-1" class="faqm-closed px-6 pb-5">
            <p class="text-gray-300 leading-relaxed">Getting started is easy. Book a free Discovery Call, and we'll discuss your challenges and goals. From there, we'll create a tailored roadmap to help you implement AI in your business.</p>
          </div>
        </div>

        <!-- Q2 -->
        <div class="bg-gray-800/50 border border-gray-700/50 rounded-lg backdrop-blur-sm">
          <button class="w-full px-6 py-5 text-left flex items-center justify-between hover:bg-gray-800/70 transition-colors duration-200 focus:outline-none rounded-lg" onclick="toggleFAQMini('faqm-2')" aria-expanded="false" aria-controls="faqm-2">
            <h3 class="text-base sm:text-lg font-semibold text-white pr-4">How do you ensure data security?</h3>
            <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-200 faqm-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div id="faqm-2" class="faqm-closed px-6 pb-5">
            <p class="text-gray-300 leading-relaxed">We prioritise security at every step. Our solutions include data encryption, secure storage, and access controls to protect your sensitive information.</p>
          </div>
        </div>

        <!-- Q4 -->
        <div class="bg-gray-800/50 border border-gray-700/50 rounded-lg backdrop-blur-sm">
          <button class="w-full px-6 py-5 text-left flex items-center justify-between hover:bg-gray-800/70 transition-colors duration-200 focus:outline-none rounded-lg" onclick="toggleFAQMini('faqm-4')" aria-expanded="false" aria-controls="faqm-4">
            <h3 class="text-base sm:text-lg font-semibold text-white pr-4">How do you measure success?</h3>
            <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-200 faqm-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div id="faqm-4" class="faqm-closed px-6 pb-5">
            <p class="text-gray-300 leading-relaxed">We focus on measurable outcomes, such as time savings, error reduction, and cost efficiency. Before starting, we work with you to define success metrics and evaluate the results at each stage.</p>
          </div>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="/faq" class="inline-flex items-center text-blue-400 hover:text-blue-300 font-medium transition-colors duration-200">See all FAQs<svg class="ml-2 w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg></a>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    window.toggleFAQMini = function(id) {
      const content = document.getElementById(id);
      const button = content.previousElementSibling;
      const icon = button.querySelector('.faqm-icon');
      const isClosed = content.classList.contains('faqm-closed');

      document.querySelectorAll('[id^="faqm-"]').forEach(el => {
        if (el !== content) {
          el.classList.add('faqm-closed');
          const otherBtn = el.previousElementSibling;
          const otherIcon = otherBtn.querySelector('.faqm-icon');
          otherBtn.setAttribute('aria-expanded', 'false');
          otherIcon.style.transform = 'rotate(0deg)';
        }
      });

      if (isClosed) {
        content.classList.remove('faqm-closed');
        button.setAttribute('aria-expanded', 'true');
        icon.style.transform = 'rotate(180deg)';
      } else {
        content.classList.add('faqm-closed');
        button.setAttribute('aria-expanded', 'false');
        icon.style.transform = 'rotate(0deg)';
      }
    }
  });
</script>

<style>
  [id^="faqm-"] {
    max-height: 400px;
    overflow: hidden;
    opacity: 1;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease 0.05s, padding 0.4s ease;
  }
  [id^="faqm-"].faqm-closed {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease, padding 0.4s ease;
  }
</style>
