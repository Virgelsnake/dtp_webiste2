---
// Modern navigation bar inspired by Deepgram design
---

<header class="w-full bg-gray-900/95 backdrop-blur-sm text-white fixed top-0 z-50 border-b border-gray-800">
  <nav class="container mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="hover:text-blue-400 transition-colors duration-200 flex items-center space-x-3">
          <img src="/images/DTP logo - White-2.png" alt="Digital Technology Partner" class="h-10 w-auto" onerror="this.style.display='none'">
          <span class="text-xl font-bold text-white">Digital Technology Partner</span>
        </a>
      </div>
      
      <!-- Main Navigation -->
      <ul class="hidden lg:flex items-center space-x-8 text-sm font-medium">
        <li><a href="/" class="text-sm font-medium hover:text-blue-400 transition-colors duration-200">Home</a></li>
        <li><a href="/services" class="text-sm font-medium hover:text-blue-400 transition-colors duration-200">Our Approach</a></li>
        <li><a href="/case-studies" class="text-sm font-medium hover:text-blue-400 transition-colors duration-200">Case Studies</a></li>
        <li><a href="/faq" class="hover:text-blue-400 transition-colors duration-200">FAQ</a></li>
        <li><a href="/news2" class="hover:text-blue-400 transition-colors duration-200">News</a></li>
        <li><a href="/contact" class="hover:text-blue-400 transition-colors duration-200">Contact</a></li>
      </ul>
      
      <!-- CTA Buttons removed per request -->
      
      <!-- Mobile menu button -->
      <button id="mobile-menu-button" class="lg:hidden text-white hover:text-blue-400 transition-colors" aria-controls="mobile-menu" aria-expanded="false" aria-label="Toggle navigation menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
    
    <!-- Mobile Menu Panel -->
    <div id="mobile-menu" class="lg:hidden mt-3 hidden bg-gray-900/95 border border-gray-800 rounded-xl shadow-xl">
      <ul class="flex flex-col divide-y divide-gray-800">
        <li><a href="/" class="block px-4 py-3 text-sm hover:text-blue-400 hover:bg-gray-800/60 rounded-t-xl transition-colors focus:outline-none focus-visible:outline-none focus:ring-0 focus-visible:ring-0">Home</a></li>
        <li><a href="/services" class="block px-4 py-3 text-sm hover:text-blue-400 hover:bg-gray-800/60 transition-colors focus:outline-none focus-visible:outline-none focus:ring-0 focus-visible:ring-0">Our Approach</a></li>
        <li><a href="/case-studies" class="block px-4 py-3 text-sm hover:text-blue-400 hover:bg-gray-800/60 transition-colors focus:outline-none focus-visible:outline-none focus:ring-0 focus-visible:ring-0">Case Studies</a></li>
        <li><a href="/faq" class="block px-4 py-3 text-sm hover:text-blue-400 hover:bg-gray-800/60 transition-colors focus:outline-none focus-visible:outline-none focus:ring-0 focus-visible:ring-0">FAQ</a></li>
        <li><a href="/news2" class="block px-4 py-3 text-sm hover:text-blue-400 hover:bg-gray-800/60 transition-colors focus:outline-none focus-visible:outline-none focus:ring-0 focus-visible:ring-0">News</a></li>
        <li><a href="/contact" class="block px-4 py-3 text-sm hover:text-blue-400 hover:bg-gray-800/60 transition-colors focus:outline-none focus-visible:outline-none focus:ring-0 focus-visible:ring-0">Contact</a></li>
      </ul>
      <div class="p-4">
        <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="w-full inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-6 rounded-lg text-sm transition-all duration-200 shadow-lg hover:shadow-xl">Book a Discovery Call</a>
      </div>
    </div>
  </nav>
  
  <!-- Temporary instrumentation + minimal toggle logic (remove before prod) -->
  <script is:client>
    const header = document.querySelector('header');
    const btn = document.getElementById('mobile-menu-button');
    const panel = document.getElementById('mobile-menu');
    const firstLink = panel?.querySelector('a');

    const getBucket = (w) => (w < 1024 ? 'mobile' : 'desktop');
    const setBpData = () => {
      const w = window.innerWidth;
      const bucket = getBucket(w);
      header?.setAttribute('data-bp', bucket);
      const hamburgerVisible = !!btn && getComputedStyle(btn).display !== 'none';
      const desktopNav = document.querySelector('ul.hidden.lg\\:flex');
      const desktopVisible = !!desktopNav && getComputedStyle(desktopNav).display !== 'none';
      console.log('[nav]', { width: w, bucket, hamburgerVisible, desktopVisible, menuOpen: panel && !panel.classList.contains('hidden') });
    };

    // Initial mark
    setBpData();
    window.addEventListener('resize', () => setBpData());

    const closeMenu = () => {
      if (!panel) return;
      panel.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      header?.setAttribute('data-menu-open', 'false');
    };

    const openMenu = () => {
      if (!panel) return;
      panel.classList.remove('hidden');
      btn?.setAttribute('aria-expanded', 'true');
      header?.setAttribute('data-menu-open', 'true');
      // Focus first link for basic a11y
      firstLink?.focus({ preventScroll: true });
    };

    btn?.addEventListener('click', () => {
      if (!panel) return;
      const isHidden = panel.classList.contains('hidden');
      isHidden ? openMenu() : closeMenu();
      setBpData();
    });

    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  </script>
</header>
