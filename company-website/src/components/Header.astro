---
// Modern navigation bar inspired by Deepgram design
---

<header class="w-full bg-gray-900/95 backdrop-blur-sm text-white fixed top-0 z-50 border-b border-gray-800">
  <nav class="container mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="hover:text-blue-400 transition-colors duration-200 flex items-center space-x-3">
          <img src="/images/DTP logo - White-2.png" alt="Digital Technology Partner" class="h-10 w-auto" onerror="this.style.display='none'">
          <span class="text-xl font-bold text-white">Digital Technology Partner</span>
        </a>
      </div>
      
      <!-- Main Navigation -->
      <ul class="hidden lg:flex items-center space-x-8 text-sm font-medium">
        <li><a href="/" class="hover:text-blue-400 transition-colors duration-200">Home</a></li>
        <li><a href="/home1" class="hover:text-blue-400 transition-colors duration-200">Our Approach</a></li>
        <li><a href="/services" class="hover:text-blue-400 transition-colors duration-200">Services</a></li>
        <li><a href="/sectors" class="hover:text-blue-400 transition-colors duration-200">Sectors & Use Cases</a></li>
        <li><a href="/case-studies" class="hover:text-blue-400 transition-colors duration-200">Case Studies</a></li>
        <li><a href="/resources" class="hover:text-blue-400 transition-colors duration-200">Resources</a></li>
        <li><a href="/about" class="hover:text-blue-400 transition-colors duration-200">About</a></li>
        <li><a href="/contact" class="hover:text-blue-400 transition-colors duration-200">Contact</a></li>
        <li class="relative group">
          <button class="hover:text-blue-400 transition-colors duration-200 flex items-center space-x-1">
            <span>Draft</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <!-- Draft dropdown -->
          <div class="absolute top-full left-0 mt-2 w-64 bg-gray-800 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="p-4 space-y-2">
              <a href="/location" class="block px-3 py-2 rounded hover:bg-gray-700 transition-colors">Location</a>
              <a href="/news" class="block px-3 py-2 rounded hover:bg-gray-700 transition-colors">News</a>
              <a href="/news2" class="block px-3 py-2 rounded hover:bg-gray-700 transition-colors">News 2</a>
              <a href="/faq" class="block px-3 py-2 rounded hover:bg-gray-700 transition-colors">FAQ</a>
            </div>
          </div>
        </li>
      </ul>
      
      <!-- CTA Buttons -->
      <div class="hidden md:flex items-center space-x-4">
        <a href="/contact" class="text-sm font-medium hover:text-blue-400 transition-colors duration-200">
          Contact Us
        </a>
        <a href="/contact" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-6 rounded-lg text-sm transition-all duration-200 shadow-lg hover:shadow-xl">
          Book a Discovery Workshop
        </a>
      </div>
      
      <!-- Mobile menu button -->
      <button class="md:hidden text-white hover:text-blue-400 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>
