---
// V2: Midnight Authority Navigation
---

<header class="ma-header">
  <nav class="ma-container ma-nav-inner">
    <a href="/" class="ma-nav-logo">
      <img src="/images/DTP logo - White-2.png" alt="DTP" class="ma-logo-img" />
    </a>

    <ul class="ma-nav-links" id="desktop-nav">
      <li><a href="/">Home</a></li>
      <li><a href="/services">Our Approach</a></li>
      <li><a href="/case-studies">Case Studies</a></li>
      <li><a href="/faq">FAQ</a></li>
      <li><a href="/news">News</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>

    <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="ma-btn ma-btn-mint ma-nav-cta">Book a Call</a>

    <button id="mobile-menu-button" class="ma-nav-hamburger" aria-controls="mobile-menu" aria-expanded="false" aria-label="Toggle navigation menu">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="ma-mobile-menu hidden">
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/services">Our Approach</a></li>
      <li><a href="/case-studies">Case Studies</a></li>
      <li><a href="/faq">FAQ</a></li>
      <li><a href="/news">News</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
    <div class="ma-mobile-cta">
      <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="ma-btn ma-btn-mint" style="width:100%;justify-content:center;">Book a Discovery Call</a>
    </div>
  </div>
</header>

<style>
  .ma-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.88);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--ma-border);
  }

  .ma-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .ma-nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .ma-logo-img {
    height: 32px;
    width: auto;
  }

  .ma-nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .ma-nav-links a {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ma-text-dim);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .ma-nav-links a:hover { color: var(--ma-mint); }

  .ma-nav-cta {
    font-size: 0.82rem !important;
    padding: 0.45rem 1.1rem !important;
  }

  .ma-nav-hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--ma-white);
    cursor: pointer;
    padding: 0.625rem; /* Increased for 44x44px touch target */
    min-width: 44px;
    min-height: 44px;
    transition: color 200ms ease;
  }

  .ma-nav-hamburger:hover { color: var(--ma-mint); }

  /* Mobile Menu */
  .ma-mobile-menu {
    background: rgba(10, 10, 15, 0.98);
    border-top: 1px solid var(--ma-border);
    padding: 1rem 2rem 1.5rem;
  }

  .ma-mobile-menu.hidden { display: none; }

  .ma-mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .ma-mobile-menu li {
    border-bottom: 1px solid var(--ma-border);
  }

  .ma-mobile-menu a {
    display: block;
    padding: 0.85rem 0;
    min-height: 44px; /* WCAG touch target minimum */
    font-size: 0.92rem;
    color: var(--ma-text-dim);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .ma-mobile-menu a:hover { color: var(--ma-mint); }

  .ma-mobile-cta { margin-top: 1rem; }

  @media (max-width: 1023px) {
    .ma-nav-links { display: none; }
    .ma-nav-cta { display: none; }
    .ma-nav-hamburger { display: block; }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-button');
  const panel = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    if (!panel) return;
    const isHidden = panel.classList.contains('hidden');
    panel.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel && !panel.classList.contains('hidden')) {
      panel.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
