<section class="py-20 sm:py-32 bg-gray-900">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">What we're asked to fix most often</h2>
    </div>
    <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- Operations Automation Card -->
      <div class="bento-card group">
