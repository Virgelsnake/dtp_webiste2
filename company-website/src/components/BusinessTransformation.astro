              </svg>
            </div>
            <!-- Glowing effect -->
            <div class="absolute inset-0 w-24 h-24 rounded-full bg-green-500/10 group-hover:animate-ping"></div>
          </div>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4 text-center">Operations Automation</h3>
        <p class="text-gray-300 mb-6 text-center">Remove manual steps, reduce errors, and speed up routine work.</p>
        <div class="text-center">
          <a href="#" class="inline-flex items-center px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">
            See how this works
          </a>
        </div>
      </div>

      <!-- Data & Reporting Card -->
      <div class="bento-card group">
        <div class="flex justify-center mb-8">
          <div class="relative">
            <!-- Animated outer ring -->
            <div class="w-24 h-24 rounded-full border-2 border-blue-500/30 group-hover:animate-spin-slow"></div>
            <!-- Glowing middle ring -->
            <div class="absolute inset-2 w-20 h-20 rounded-full border border-blue-400/50 group-hover:animate-pulse"></div>
            <!-- Inner circle with icon -->
            <div class="absolute inset-4 w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center border border-blue-500/40">
              <svg class="w-8 h-8 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M3,3H21A1,1 0 0,1 22,4V20A1,1 0 0,1 21,21H3A1,1 0 0,1 2,20V4A1,1 0 0,1 3,3M4,5V19H20V5H4M6,7H18V9H6V7M6,11H18V13H6V11M6,15H18V17H6V15Z"/>
              </svg>
            </div>
            <!-- Glowing effect -->
            <div class="absolute inset-0 w-24 h-24 rounded-full bg-blue-500/10 group-hover:animate-ping"></div>
          </div>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4 text-center">Data & Reporting</h3>
        <p class="text-gray-300 mb-6 text-center">Bring data together and give teams clear dashboards and alerts.</p>
        <div class="text-center">
          <a href="#" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
            See how this works
          </a>
        </div>
      </div>

      <!-- AI Assistants Card -->
      <div class="bento-card group">
        <div class="flex justify-center mb-8">
          <div class="relative">
            <!-- Animated outer ring -->
            <div class="w-24 h-24 rounded-full border-2 border-cyan-500/30 group-hover:animate-spin-slow"></div>
            <!-- Glowing middle ring -->
            <div class="absolute inset-2 w-20 h-20 rounded-full border border-cyan-400/50 group-hover:animate-pulse"></div>
            <!-- Inner circle with icon -->
            <div class="absolute inset-4 w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center border border-cyan-500/40">
              <svg class="w-8 h-8 text-cyan-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,2A2,2 0 0,1 14,4C14,4.74 13.6,5.39 13,5.73V7H14A7,7 0 0,1 21,14H22A1,1 0 0,1 23,15V18A1,1 0 0,1 22,19H21V20A2,2 0 0,1 19,22H5A2,2 0 0,1 3,20V19H2A1,1 0 0,1 1,18V15A1,1 0 0,1 2,14H3A7,7 0 0,1 10,7H11V5.73C10.4,5.39 10,4.74 10,4A2,2 0 0,1 12,2M7.5,13A2.5,2.5 0 0,0 5,15.5A2.5,2.5 0 0,0 7.5,18A2.5,2.5 0 0,0 10,15.5A2.5,2.5 0 0,0 7.5,13M16.5,13A2.5,2.5 0 0,0 14,15.5A2.5,2.5 0 0,0 16.5,18A2.5,2.5 0 0,0 19,15.5A2.5,2.5 0 0,0 16.5,13Z"/>
              </svg>
            </div>
            <!-- Glowing effect -->
            <div class="absolute inset-0 w-24 h-24 rounded-full bg-cyan-500/10 group-hover:animate-ping"></div>
          </div>
        </div>
        <h3 class="text-xl font-semibold text-white mb-4 text-center">AI Assistants for Teams</h3>
        <p class="text-gray-300 mb-6 text-center">Turn meetings and messages into organised tasks and updates.</p>
        <div class="text-center">
          <a href="#" class="inline-flex items-center px-4 py-2 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-colors">
            See how this works
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bento-card {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
    border-radius: 1.5rem;
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .bento-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 30% 20%, rgba(59, 130, 246, 0.15), transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .bento-card:hover {
    transform: translateY(-8px);
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 25px 50px -12px rgba(59, 130, 246, 0.25), 0 20px 25px -5px rgba(0, 0, 0, 0.4);
  }

  .bento-card:hover::before {
    opacity: 1;
  }

  /* Icon animation styles */
  .bento-card .w-24.h-24.rounded-full.border-2 {
    transition: transform 0.3s ease;
  }

  .bento-card:hover .w-24.h-24.rounded-full.border-2 {
    animation: spin-slow 8s linear infinite;
  }

  .bento-card .absolute.inset-2.w-20.h-20.rounded-full.border {
    transition: opacity 0.3s ease;
  }

  .bento-card:hover .absolute.inset-2.w-20.h-20.rounded-full.border {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .bento-card .absolute.inset-0.w-24.h-24.rounded-full {
    transition: opacity 0.3s ease;
  }

  .bento-card:hover .absolute.inset-0.w-24.h-24.rounded-full {
    animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  
  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }
</style>
