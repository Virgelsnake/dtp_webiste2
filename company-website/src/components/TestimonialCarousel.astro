---
// Testimonial data - replicating Deepgram's style with enterprise and startup testimonials
const testimonials = [
  {
    quote: `Digital Technology Partner completely transformed our quotation process. Their tailored AI
solution helped us cut preparation time by 40% and eliminate errors. It’s been a game-
changer for our operations.`,
    author: "Managing Director",
    title: "",
    company: "",
    logo: "/icons/company-1.svg",
    type: "",
    rating: 4.9
  },
  {
    quote: `Thanks to Digital Technology Partner, we’ve implemented predictive models that have
improved our operational efficiency and provided critical insights. Their expertise is
unmatched.`,
    author: "CTO",
    title: "",
    company: "",
    logo: "/icons/company-2.svg",
    type: "",
    rating: 4.8
  },
  {
    quote: `Digital Technology Partner revolutionised our workshop maintenance operations. Their WhatsApp-integrated solution automated our entire servicing schedule, ensuring every machine gets maintained on time by the right technician. We've eliminated missed services and now have complete visibility of all maintenance activities through automated photo documentation and real-time manager notifications.`,
    author: "COO",
    title: "",
    company: "",
    logo: "/icons/company-3.svg",
    type: "",
    rating: 4.7
  },
  {
    quote: `Digital Technology Partner transformed how I manage tasks across my two companies. Their AI solution captures every action item from our leadership meetings across different platforms and automatically distributes them to the right people via WhatsApp. My team can now update progress naturally using text or voice messages throughout their day, and I can check on any task status instantly. It's eliminated the communication gaps between our meetings and significantly improved accountability across both organizations.`,
    author: "CEO",
    title: "",
    company: "",
    logo: "/icons/company-4.svg",
    type: "",
    rating: 4.9
  }
];
---

<section class="testimonial-section bg-gray-900 py-24 sm:py-32">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mb-4">
        What clients say
      </h2>
    </div>

    <!-- Testimonial Carousel -->
    <div class="testimonial-carousel-container relative overflow-hidden">
      <div class="testimonial-track flex">
        {testimonials.concat(testimonials).map((testimonial, index) => (
          <div class="testimonial-card flex-shrink-0 w-full md:w-1/2 lg:w-1/3 px-4">
            <div class="bg-gray-800 rounded-xl p-8 h-full border border-gray-700 hover:border-gray-600 transition-all duration-300 hover:transform hover:scale-105">
              <div class="flex items-start mb-6">
                <div class="company-logo w-12 h-12 bg-white rounded-lg flex items-center justify-center mr-4 p-2">
                  <img src="/images/dtp-logo.png" alt="Digital Technology Partner" class="w-full h-full object-contain">
                </div>
                <div class="flex-1">
                  {testimonial.company && (
                    <div class="company-name text-sm font-semibold text-gray-300 mb-1">
                      {testimonial.company}
                    </div>
                  )}
                  {testimonial.type && (
                    <div class="company-type text-xs text-gray-500 uppercase tracking-wide">
                      {testimonial.type}
                    </div>
                  )}
                  <!-- Star rating -->
                  <div class="flex items-center gap-1 mt-2" aria-label={`Rated ${testimonial.rating?.toFixed ? testimonial.rating.toFixed(1) : testimonial.rating}/5`}>
                    {[0,1,2,3,4].map((i) => {
                      const percent = Math.max(0, Math.min(100, Math.round(((testimonial.rating ?? 5) - i) * 100)));
                      return (
                        <span class="relative inline-block w-5 h-5" aria-hidden="true">
                          {/* Base star (gray) */}
                          <svg class="w-5 h-5 text-gray-600" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.802 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.538 1.118l-2.802-2.034a1 1 0 00-1.175 0l-2.802 2.034c-.783.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                          </svg>
                          {/* Filled part (yellow) */}
                          <span class="absolute inset-0 overflow-hidden" style={`width: ${percent}%`}>
                            <svg class="w-5 h-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.802 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.538 1.118l-2.802-2.034a1 1 0 00-1.175 0l-2.802 2.034c-.783.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                          </span>
                        </span>
                      );
                    })}
                    <span class="ml-2 text-sm text-gray-400">{(testimonial.rating ?? 5).toFixed ? (testimonial.rating as number).toFixed(1) : testimonial.rating}/5</span>
                  </div>
                </div>
              </div>
              
              <blockquote class="text-gray-200 text-lg leading-relaxed mb-6 italic">
                "{testimonial.quote}"
              </blockquote>
              
              <div class="author-info">
                <div class="author-name text-white font-semibold">
                  {testimonial.author}
                </div>
                <div class="author-title text-gray-400 text-sm">
                  {testimonial.title}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-12">
      <a href="/case-studies" class="inline-flex items-center text-blue-400 hover:text-blue-300 font-medium">
        Read full case studies
      </a>
    </div>

  </div>
</section>

<style>
  .testimonial-carousel-container {
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    /* Improve touch interactions on mobile: allow vertical scrolling while dragging horizontally */
    touch-action: pan-y;
    cursor: grab;
  }

  .testimonial-track {
    will-change: transform;
  }

  .testimonial-card {
    min-height: 320px;
  }



  /* Responsive adjustments */
  @media (max-width: 768px) {
    .testimonial-track {
      animation-duration: 34s;
    }
    
    .testimonial-card {
      min-height: 280px;
    }
  }

  /* Enhanced hover effects */
  .testimonial-card:hover .company-logo {
    transform: rotate(5deg) scale(1.05);
    transition: all 0.3s ease;
  }

  .testimonial-card:hover blockquote {
    color: #f3f4f6;
    transition: color 0.3s ease;
  }
</style>

<script>
  // Seamless, continuous marquee-style scroller without jumps
  class ContinuousScroller {
    constructor() {
      this.container = document.querySelector('.testimonial-carousel-container');
      this.track = document.querySelector('.testimonial-track');
      this.offset = 0;
      this.speed = 80; // px per second (increased)
      this.running = true;
      this.lastTs = 0;
      this.halfWidth = 0;
      this.rafId = null;
      this.onResize = this.recalculate.bind(this);
      // drag state
      this.dragging = false;
      this.startX = 0;
      this.startOffset = 0;
      this.init();
    }

    init() {
      if (!this.track || !this.container) return;
      this.recalculate();
      this.bindHover();
      this.bindDrag();
      this.loop = this.loop.bind(this);
      this.rafId = requestAnimationFrame(this.loop);
      window.addEventListener('resize', this.onResize);
    }

    recalculate() {
      // track contains duplicated slides; half of scrollWidth is one full set
      this.halfWidth = this.track.scrollWidth / 2;
      // Prevent large jumps on resize
      this.offset = this.offset % this.halfWidth;
      this.applyTransform();
    }

    bindHover() {
      this.container.addEventListener('mouseenter', () => { this.running = false; });
      this.container.addEventListener('mouseleave', () => { 
        this.running = true; 
        this.lastTs = 0; // reset timing to avoid speed spike
      });
    }

    bindDrag() {
      const start = (clientX) => {
        this.dragging = true;
        this.running = false;
        this.startX = clientX;
        this.startOffset = this.offset;
      };
      const move = (clientX) => {
        if (!this.dragging) return;
        const dx = clientX - this.startX;
        this.offset = this.startOffset + dx;
        // wrap while dragging
        if (this.offset > 0) this.offset -= this.halfWidth * Math.ceil(this.offset / this.halfWidth);
        if (-this.offset >= this.halfWidth) this.offset += this.halfWidth * Math.ceil((-this.offset) / this.halfWidth);
        this.applyTransform();
      };
      const end = () => {
        if (!this.dragging) return;
        this.dragging = false;
        this.running = true;
        this.lastTs = 0;
      };

      // Pointer events (covers mouse, touch, pen)
      this.container.addEventListener('pointerdown', (e) => {
        this.container.setPointerCapture?.(e.pointerId);
        start(e.clientX);
      }, { passive: true });
      window.addEventListener('pointermove', (e) => move(e.clientX), { passive: true });
      window.addEventListener('pointerup', end, { passive: true });
      window.addEventListener('pointercancel', end, { passive: true });
    }

    loop(ts) {
      if (!this.lastTs) this.lastTs = ts;
      const dt = (ts - this.lastTs) / 1000; // seconds
      this.lastTs = ts;
      if (this.running) {
        this.offset -= this.speed * dt;
        // Wrap seamlessly at exactly one set width
        if (-this.offset >= this.halfWidth) {
          this.offset += this.halfWidth;
        }
        this.applyTransform();
      }
      this.rafId = requestAnimationFrame(this.loop);
    }

    applyTransform() {
      this.track.style.transform = `translate3d(${this.offset}px, 0, 0)`;
    }
  }

  // Initialize on DOM ready
  document.addEventListener('DOMContentLoaded', () => {
    new ContinuousScroller();
  });

  // Intersection Observer for animation triggers
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-in');
      }
    });
  }, observerOptions);

  // Observe testimonial cards for entrance animations
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.testimonial-card');
    cards.forEach(card => observer.observe(card));
  });
</script>
