---
export interface Props {
  title: string;
  description?: string;
  image?: string; // optional per-page OG image (absolute or root-relative)
}

const DEFAULT_DESC = 'Digital Technology Partner (DTP) helps founders and teams turn ideas into products: Discovery → PoC → MVP → Pilot → Full Launch.';
const DEFAULT_IMAGE = '/images/og-default.jpg'; // 1200x630 recommended

const { title, description = DEFAULT_DESC, image = DEFAULT_IMAGE } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {/* Canonical URL */}
    {(() => {
      const canonical = new URL(Astro.url.pathname, Astro.site).toString();
      return <link rel="canonical" href={canonical} />
    })()}

    {/* Open Graph for rich previews */}
    {(() => {
      const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
      const imageUrl = (image?.startsWith('http') ? image : new URL(image, Astro.site).toString());
      return (
        <fragment>
          <meta property="og:type" content="website" />
          <meta property="og:title" content={title} />
          <meta property="og:description" content={description} />
          <meta property="og:url" content={pageUrl} />
          <meta property="og:image" content={imageUrl} />
          <meta property="og:site_name" content="Digital Technology Partner" />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:alt" content="Digital Technology Partner (DTP)" />
        </fragment>
      );
    })()}

    {/* Twitter Cards */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {(() => {
      const imageUrl = (image?.startsWith('http') ? image : new URL(image, Astro.site).toString());
      return <meta name="twitter:image" content={imageUrl} />
    })()}
  </head>
  <body class="min-h-screen bg-white">
    <slot />
  </body>
</html>
