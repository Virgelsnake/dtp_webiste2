---
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';
import '../styles/v2-design-system.css';

export interface Props {
	title: string;
	description?: string;
	image?: string;
}

const DEFAULT_DESC = 'Digital Technology Partner (DTP) helps founders and teams turn ideas into products: Discovery → PoC → MVP → Pilot → Full Launch.';
const DEFAULT_IMAGE = '/images/og-default.jpg';

const { title, description = DEFAULT_DESC, image = DEFAULT_IMAGE } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="shortcut icon" href="/favicon-32x32.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- V2: Midnight Authority Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

		{/* Canonical URL */}
		{(() => {
		  const canonical = new URL(Astro.url.pathname, Astro.site).toString();
		  return <link rel="canonical" href={canonical} />
		})()}

		{/* Open Graph (WhatsApp/LinkedIn/Slack) */}
		{(() => {
		  const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
		  const img = image.startsWith('http') ? image : new URL(image, Astro.site).toString();
		  const desc = description;
		  return (
		    <fragment>
		      <meta property="og:type" content="website" />
		      <meta property="og:title" content={title} />
		      <meta property="og:description" content={desc} />
		      <meta property="og:url" content={pageUrl} />
		      <meta property="og:image" content={img} />
		      <meta property="og:site_name" content="Digital Technology Partner" />
		      <meta property="og:image:width" content="1200" />
		      <meta property="og:image:height" content="630" />
		      <meta property="og:image:alt" content="Digital Technology Partner (DTP)" />
		    </fragment>
		  );
		})()}

		{/* Twitter Cards */}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{(() => {
		  const img = image.startsWith('http') ? image : new URL(image, Astro.site).toString();
		  return <meta name="twitter:image" content={img} />
		})()}
	</head>
	<body>
		<slot />
    <Footer />
    <CommandPalette />
	</body>
</html>
