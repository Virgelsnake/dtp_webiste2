---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
---

<Layout title="Privacy Policy - 10 Touches (TestFlight Beta)" description="Privacy Policy for 10 Touches TestFlight Beta - Your personal CRM app with optional bug reporting.">
  <div class="relative bg-gray-900 text-white min-h-screen">
    <Header />
    
    <main class="relative pt-24 pb-16">
      <div class="container mx-auto px-6 max-w-4xl">
        
        <!-- Hero Header with Animated Rings -->
        <div class="text-center mb-16">
          <div class="relative inline-flex items-center justify-center mb-6">
            <div class="absolute w-24 h-24 rounded-2xl border-2 border-blue-500/30 animate-spin-slow"></div>
            <div class="absolute inset-2 w-20 h-20 rounded-2xl border border-blue-400/50 animate-pulse"></div>
            <div class="relative w-20 h-20 rounded-2xl bg-gradient-to-br from-blue-600 to-blue-800 flex items-center justify-center shadow-lg shadow-blue-500/50 border border-blue-500/40">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"></path>
              </svg>
            </div>
            <div class="absolute inset-0 w-24 h-24 rounded-2xl bg-blue-500/10 animate-ping opacity-75"></div>
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">Privacy Policy</h1>
          <p class="text-xl text-gray-300 mb-2">10 Touches - TestFlight Beta</p>
          <p class="text-sm text-gray-400">Last Updated: January 2026</p>
        </div>

        <!-- Overview Section -->
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6">Overview</h2>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed mb-4">
              This Privacy Policy applies to the <strong>TestFlight beta version</strong> of 10 Touches. It supplements our standard Privacy Policy with additional disclosures about data collected through the in-app bug reporting feature.
            </p>
            <p class="text-gray-300 text-lg leading-relaxed">
              <strong>Key Point:</strong> All your CRM data (clients, opportunities, touchpoints) remains stored locally on your device, exactly as described in our standard Privacy Policy. The bug reporting feature is the only exception, and it requires your explicit consent.
            </p>
          </div>
        </section>

        <!-- Standard Privacy (Unchanged) -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">1. Standard Privacy (Unchanged)</h2>
          <div class="bento-card mb-6">
            <p class="text-gray-300 text-lg leading-relaxed mb-4">
              All provisions of our <a href="https://digitaltechnologypartner.ai/10-touches/privacy" class="text-blue-400 hover:text-blue-300 underline">standard Privacy Policy</a> apply to this beta version. Your client data:
            </p>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bento-card">
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-gray-300">Remains on your device</span>
              </div>
            </div>
            <div class="bento-card">
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-gray-300">Is never transmitted to our servers</span>
              </div>
            </div>
            <div class="bento-card">
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-gray-300">Is never shared with third parties</span>
              </div>
            </div>
            <div class="bento-card">
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span class="text-gray-300">Is NOT included in bug reports</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Bug Reporting Feature -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">2. Bug Reporting Feature (TestFlight Only)</h2>
          <div class="mb-12 p-8 rounded-2xl bg-gradient-to-br from-orange-600/20 to-orange-800/20 border border-orange-500/30 backdrop-blur-sm">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-600 flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-3 text-orange-400">TestFlight Beta Feature</h3>
                <p class="text-gray-300 text-lg leading-relaxed">
                  The TestFlight beta includes an optional bug reporting feature. When you choose to submit a bug report, we collect the following:
                </p>
              </div>
            </div>
          </div>

          <!-- What We Collect Table -->
          <h3 class="text-2xl font-bold mb-4">What We Collect</h3>
          <div class="overflow-hidden rounded-2xl border border-gray-700 mb-8">
            <table class="w-full">
              <thead>
                <tr class="bg-blue-600">
                  <th class="px-6 py-4 text-left text-white font-semibold">Data Type</th>
                  <th class="px-6 py-4 text-left text-white font-semibold">Purpose</th>
                  <th class="px-6 py-4 text-left text-white font-semibold">Your Control</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-700">
                <tr class="bg-gray-800/50 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Bug description (text)</td>
                  <td class="px-6 py-4 text-gray-300">Understand the issue</td>
                  <td class="px-6 py-4 text-blue-400 font-semibold">You write/edit this</td>
                </tr>
                <tr class="bg-gray-800/30 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Device model</td>
                  <td class="px-6 py-4 text-gray-300">Identify device-specific bugs</td>
                  <td class="px-6 py-4 text-gray-400">Automatic</td>
                </tr>
                <tr class="bg-gray-800/50 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">iOS version</td>
                  <td class="px-6 py-4 text-gray-300">Identify OS-specific bugs</td>
                  <td class="px-6 py-4 text-gray-400">Automatic</td>
                </tr>
                <tr class="bg-gray-800/30 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">App version & build</td>
                  <td class="px-6 py-4 text-gray-300">Track which version has the bug</td>
                  <td class="px-6 py-4 text-gray-400">Automatic</td>
                </tr>
                <tr class="bg-gray-800/50 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Timestamp</td>
                  <td class="px-6 py-4 text-gray-300">Know when the bug occurred</td>
                  <td class="px-6 py-4 text-gray-400">Automatic</td>
                </tr>
                <tr class="bg-gray-800/30 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Recent app logs</td>
                  <td class="px-6 py-4 text-gray-300">Technical debugging</td>
                  <td class="px-6 py-4 text-gray-400">Filtered for privacy</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- What We Do NOT Collect -->
          <h3 class="text-2xl font-bold mb-4">What We Do NOT Collect</h3>
          <div class="p-8 rounded-2xl bg-gradient-to-br from-green-600/20 to-emerald-800/20 border border-green-500/30 backdrop-blur-sm mb-8">
            <ul class="space-y-3 text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span>Your client data (names, emails, phone numbers)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span>Your opportunities or touchpoints</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span>Audio recordings (voice is transcribed locally)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span>Screenshots (use TestFlight's built-in feature)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span>Location data</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span>Device identifiers for tracking</span>
              </li>
            </ul>
          </div>

          <!-- How Voice Input Works -->
          <h3 class="text-2xl font-bold mb-4">How Voice Input Works</h3>
          <div class="bento-card mb-6">
            <p class="text-gray-300 text-lg leading-relaxed mb-4">When you use voice input to describe a bug:</p>
            <ol class="space-y-3 text-gray-300 list-decimal list-inside">
              <li>Your speech is processed <strong>on your device</strong> using Apple's Speech framework</li>
              <li>Only the <strong>text transcript</strong> is included in the report</li>
              <li>The audio recording is <strong>never transmitted</strong>—it stays on your device temporarily and is discarded</li>
            </ol>
          </div>

          <!-- Privacy Protections for Logs -->
          <h3 class="text-2xl font-bold mb-4">Privacy Protections for Logs</h3>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed mb-4">App logs included in bug reports are automatically filtered to remove:</p>
            <ul class="space-y-2 text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Email addresses</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Phone numbers</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Passwords, tokens, or API keys</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Any other potentially sensitive information</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- How We Use Bug Report Data -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">3. How We Use Bug Report Data</h2>
          <div class="bento-card mb-6">
            <p class="text-gray-300 text-lg leading-relaxed mb-4">Bug reports are used exclusively to:</p>
            <ul class="space-y-2 text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Identify and fix bugs before public release</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Improve app stability and performance</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Understand how issues occur in real-world usage</span>
              </li>
            </ul>
          </div>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed mb-4">Bug reports are:</p>
            <ul class="space-y-2 text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Reviewed only by the development team</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Not shared with third parties</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Not used for advertising or marketing</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Not linked to your identity beyond the report itself</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- Data Retention -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">4. Data Retention</h2>
          <div class="bento-card">
            <ul class="space-y-3 text-gray-300 text-lg">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Bug reports are retained for the duration of the TestFlight testing period</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                <span>Reports are deleted within <strong>30 days</strong> of the public App Store release</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <span>You can request deletion of your reports at any time by contacting us</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- Your Consent -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">5. Your Consent</h2>
          <div class="mb-6 p-8 rounded-2xl bg-gradient-to-br from-purple-600/20 to-purple-800/20 border border-purple-500/30 backdrop-blur-sm">
            <h3 class="text-2xl font-bold mb-4 text-purple-400">Bug Reporting is Entirely Optional</h3>
            <p class="text-gray-300 text-lg leading-relaxed mb-4">Before submitting any bug report:</p>
            <ol class="space-y-3 text-gray-300 list-decimal list-inside">
              <li>You will see a clear summary of what data will be collected</li>
              <li>You must explicitly tap "I Understand & Continue" to proceed</li>
              <li>You can cancel at any time before submission</li>
            </ol>
          </div>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed mb-4">If you prefer not to use our bug reporting feature, you can still provide feedback through:</p>
            <ul class="space-y-2 text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>TestFlight's built-in screenshot feedback (shake to report)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Email directly to <a href="mailto:feedback@digitaltechnologypartner.ai" class="text-blue-400 hover:text-blue-300 underline">feedback@digitaltechnologypartner.ai</a></span>
              </li>
            </ul>
          </div>
        </section>

        <!-- Production Release -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">6. Production Release</h2>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed mb-4">When 10 Touches is released on the App Store:</p>
            <ul class="space-y-3 text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>The bug reporting feature may be disabled</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Our standard Privacy Policy (local-only data) will apply</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>No diagnostic data will be collected without a similar opt-in feature</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- Contact Us -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">7. Contact Us</h2>
          <div class="bento-card text-center">
            <p class="text-gray-300 text-lg mb-6">If you have questions about this Privacy Policy or your data:</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
