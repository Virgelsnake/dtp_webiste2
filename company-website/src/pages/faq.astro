---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FAQ from '../components/FAQ.astro';
---

<Layout title="FAQ - Voice AI Platform">
  <div class="min-h-screen bg-gray-900 text-white">
    <Header />
    <main class="pt-24 sm:pt-32">
      <div class="container mx-auto px-6 text-center mb-16">
        <h1 class="text-4xl font-bold tracking-tight sm:text-6xl mb-6">
          Frequently Asked Questions
        </h1>
        <p class="text-lg leading-8 text-gray-300 max-w-2xl mx-auto">
          Find answers to common questions about our voice AI platform, pricing, and services.
        </p>
      </div>
      <FAQ />
    </main>
  </div>
</Layout>
