  <!-- Benefits -->
  <section class="ma-section" id="benefits">
    <div class="ma-container">
      <div class="ma-section-header">
        <span class="ma-section-tag">// capabilities</span>
        <h2>Why organisations work with us</h2>
      </div>
      <div class="ma-grid-6">
        <div class="ma-card">
          <div class="ma-card-line"></div>
          <h3>Reduced Risk</h3>
          <p>We deliver in stages. You see progress early and avoid big-bang surprises.</p>
        </div>
        <div class="ma-card">
          <div class="ma-card-line"></div>
          <h3>Security by Design</h3>
          <p>Data protection and access controls are built in from day one.</p>
        </div>
        <div class="ma-card">
          <div class="ma-card-line"></div>
          <h3>Reliable Delivery</h3>
          <p>Clear scope, fixed steps, and regular check-ins keep work on track.</p>
        </div>
        <div class="ma-card">
          <div class="ma-card-line"></div>
          <h3>Scales with You</h3>
          <p>Start small, prove value, then roll out without rework.</p>
        </div>
        <div class="ma-card">
          <div class="ma-card-line"></div>
          <h3>Flexible Engagement</h3>
          <p>On your stack, in our cloud, or a hybrid — whatever fits.</p>
        </div>
        <div class="ma-card">
          <div class="ma-card-line"></div>
          <h3>Works With Your Tools</h3>
          <p>We integrate with common meeting, messaging, and project platforms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="ma-section ma-section-alt">
    <div class="ma-container ma-testimonial">
      <div class="ma-quote-mark">"</div>
      <blockquote>DTP understood our problem within the first meeting. The staged approach meant we could prove value to the board before committing to a full rollout.</blockquote>
      <cite>— Operations Director, Manufacturing</cite>
