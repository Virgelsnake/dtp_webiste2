---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';

const approvedNews = await getCollection('news', ({ data }) => data.approved === true);
const news = approvedNews.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const [featured, ...rest] = news;
---

<Layout
  title="Newsroom | Digital Technology Partner"
  description="AI-assisted, human-approved insights on digital transformation, automation, and operations."
>
  <Header />

  <main class="ma-section">
    <div class="ma-container">
      <div class="ma-section-header">
        <span class="ma-section-tag">// newsroom</span>
        <h1>Newsroom</h1>
      </div>

      {
        news.length === 0 ? (
          <div class="ma-benefit-card" style="margin-top: 2rem;">
            <h3>No approved articles yet</h3>
            <p>Drafts are in review. Check back soon.</p>
          </div>
        ) : (
          <div class="news-layout" style="margin-top:2rem;">
            <aside class="news-sidebar">
              <h3>Filter by Tag</h3>
              <div class="news-tag-list" id="tag-filter">
                <button data-tag="all" class="news-tag-btn active">All</button>
              </div>
            </aside>

            <section class="news-content" id="news-content">
              {featured && (
                <article
                  class="news-card news-card-featured"
                  data-tags={['featured', featured.data.category.toLowerCase(), ...(featured.data.tags || []).map((t) => t.toLowerCase())].join(',')}
                >
                  <div class="ma-card-line" />
                  <div class="news-card-meta">
                    <span class="ma-tag">Featured</span>
                    <span class="news-date">
                      {featured.data.pubDate.toLocaleDateString('en-GB', {
                        day: '2-digit',
                        month: 'short',
                        year: 'numeric',
                      })}
                    </span>
                  </div>
                  <h2><a href={`/news/${featured.slug}`}>{featured.data.title}</a></h2>
                  <p>{featured.data.description}</p>
                  <div class="news-tags">
                    {(featured.data.tags || []).slice(0, 4).map((tag) => (
                      <span class="ma-tag">#{tag}</span>
                    ))}
                  </div>
                </article>
              )}

              <div class="news-grid">
                {rest.map((article) => (
                  <article
                    class="news-card"
                    data-tags={[article.data.category.toLowerCase(), ...(article.data.tags || []).map((t) => t.toLowerCase())].join(',')}
                  >
                    <div class="ma-card-line" />
                    <div class="news-card-meta">
                      <span class="ma-tag">{article.data.category}</span>
                      <span class="news-date">
                        {article.data.pubDate.toLocaleDateString('en-GB', {
                          day: '2-digit',
                          month: 'short',
                          year: 'numeric',
                        })}
                      </span>
                    </div>
                    <h3><a href={`/news/${article.slug}`}>{article.data.title}</a></h3>
                    <p>{article.data.description}</p>
                  </article>
                ))}
              </div>
            </section>
          </div>
        )
      }
    </div>
  </main>
</Layout>

<style>
  .news-layout { display:grid; grid-template-columns: 220px 1fr; gap:1.25rem; align-items:start; }
  .news-sidebar { position:sticky; top:6rem; background:var(--ma-surface); border:1px solid var(--ma-border); border-radius:var(--ma-radius-lg); padding:1rem; }
  .news-sidebar h3 { font-size:.95rem; margin-bottom:.8rem; }
  .news-tag-list { display:flex; flex-direction:column; gap:.45rem; }
  .news-tag-btn { text-align:left; background:transparent; border:1px solid transparent; color:var(--ma-text-dim); padding:.45rem .65rem; border-radius:8px; cursor:pointer; }
  .news-tag-btn:hover { border-color:var(--ma-border); color:var(--ma-text); }
  .news-tag-btn.active { color:var(--ma-mint); background:var(--ma-mint-dim); border-color:rgba(0,229,160,.25); }

  .news-content { display:grid; gap:1rem; }
  .news-card { position:relative; background:var(--ma-surface); border:1px solid var(--ma-border); border-radius:var(--ma-radius-lg); padding:1.1rem; overflow:hidden; }
  .news-card h2,.news-card h3 { margin:.35rem 0 .5rem; line-height:1.25; }
  .news-card h2 a,.news-card h3 a { color:inherit; text-decoration:none; }
  .news-card h2 a:hover,.news-card h3 a:hover { color:var(--ma-mint); }
  .news-card p { color:var(--ma-text-secondary); margin:0; }
  .news-card-meta { display:flex; gap:.6rem; align-items:center; margin-bottom:.35rem; }
  .news-date { font-size:.78rem; color:var(--ma-text-tertiary); }
  .news-card-featured { min-height: 260px; }
  .news-tags { display:flex; gap:.4rem; flex-wrap:wrap; margin-top:1rem; }
  .news-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:1rem; }

  @media (max-width: 980px) {
    .news-layout { grid-template-columns:1fr; }
    .news-sidebar { position:static; }
    .news-tag-list { flex-direction:row; flex-wrap:wrap; }
  }
  @media (max-width: 720px) {
    .news-grid { grid-template-columns:1fr; }
  }
</style>

<script is:inline>
  (function () {
    const tagContainer = document.getElementById('tag-filter');
    const content = document.getElementById('news-content');
    if (!tagContainer || !content) return;

    const cards = Array.from(content.querySelectorAll('article'));
    const tags = new Set();
    cards.forEach((c) => {
      (c.getAttribute('data-tags') || '')
        .split(',')
        .map((x) => x.trim().toLowerCase())
        .filter(Boolean)
        .forEach((t) => tags.add(t));
    });

    const allBtn = tagContainer.querySelector('[data-tag="all"]');
    Array.from(tags).sort().forEach((tag) => {
      const value = String(tag);
      const b = document.createElement('button');
      b.className = 'news-tag-btn';
      b.setAttribute('data-tag', value);
      b.textContent = value.replace(/\b\w/g, (m) => m.toUpperCase());
      tagContainer.appendChild(b);
    });

    function activate(btn) {
      tagContainer.querySelectorAll('.news-tag-btn').forEach((x) => x.classList.remove('active'));
      btn.classList.add('active');
    }

    function filter(tag) {
      cards.forEach((c) => {
        const list = (c.getAttribute('data-tags') || '').split(',').map((x) => x.trim().toLowerCase());
        c.style.display = tag === 'all' || list.includes(tag) ? '' : 'none';
      });
    }

    tagContainer.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('.news-tag-btn');
      if (!(btn instanceof HTMLElement)) return;
      const tag = (btn.getAttribute('data-tag') || 'all').toLowerCase();
      activate(btn);
      filter(tag);
    });

    if (allBtn instanceof HTMLElement) activate(allBtn);
  })();
</script>
