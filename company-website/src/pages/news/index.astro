---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="News & Stories - Digital Technology Partner">
  <div class="min-h-screen bg-gray-900 text-white">
    <Header />
    
    <!-- Hero Section -->
    <section class="pt-32 pb-16 px-6">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-6xl font-bold mb-6 bg-gradient-to-r from-blue-400 via-purple-500 to-pink-500 bg-clip-text text-transparent">
          News & Stories
        </h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
          Stay updated with the latest developments, insights, and success stories from the world of digital transformation and AI technology.
        </p>
      </div>
    </section>

    <!-- Featured Story - Large Bento -->
    <section class="px-6 pb-16">
      <div class="max-w-7xl mx-auto">
        <div class="featured-story-container">
          <article class="featured-story group">
            <div class="story-image-grid">
              <div class="image-box box-1">
                <img src="/images/ai-transformation.jpg" alt="AI Transformation" class="story-img" onerror="this.style.display='none'">
                <div class="image-placeholder">AI</div>
              </div>
              <div class="image-box box-2">
                <img src="/images/digital-future.jpg" alt="Digital Future" class="story-img" onerror="this.style.display='none'">
                <div class="image-placeholder">TECH</div>
              </div>
              <div class="image-box box-3">
                <img src="/images/innovation.jpg" alt="Innovation" class="story-img" onerror="this.style.display='none'">
                <div class="image-placeholder">2024</div>
              </div>
              <div class="image-box box-4">
                <img src="/images/partnership.jpg" alt="Partnership" class="story-img" onerror="this.style.display='none'">
                <div class="image-placeholder">DTP</div>
              </div>
            </div>
            <div class="story-content">
              <div class="story-meta">
                <span class="story-category">Featured</span>
                <span class="story-date">December 15, 2024</span>
              </div>
              <h2 class="story-title">The Future of AI-Driven Digital Transformation</h2>
              <p class="story-excerpt">
                Exploring how artificial intelligence is reshaping the landscape of digital transformation, 
                creating unprecedented opportunities for businesses to innovate and scale.
              </p>
              <a href="#" class="story-link">Read Full Story</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- News Grid -->
    <section class="px-6 pb-24">
      <div class="max-w-7xl mx-auto">
        <div class="news-grid">
          <!-- Story 1 - 3-Piece Vertical Split -->
          <article class="news-story group">
            <div class="story-image-mosaic layout-3piece">
              <div class="mosaic-piece split-piece-1">
                <div class="logo-section" data-section="top"></div>
              </div>
              <div class="mosaic-piece split-piece-2">
                <div class="logo-section" data-section="middle"></div>
              </div>
              <div class="mosaic-piece split-piece-3">
                <div class="logo-section" data-section="bottom"></div>
              </div>
            </div>
            <div class="story-info">
              <div class="story-meta">
                <span class="story-category">Technology</span>
                <span class="story-date">Dec 10, 2024</span>
              </div>
              <h3 class="story-title">Cloud Infrastructure Revolution</h3>
              <p class="story-excerpt">How modern cloud solutions are enabling unprecedented scalability and security for enterprise applications.</p>
              <a href="#" class="story-link">Read More</a>
            </div>
          </article>

          <!-- Story 2 - 4-Piece Grid -->
          <article class="news-story group">
            <div class="story-image-mosaic layout-4piece">
              <div class="mosaic-piece grid-piece-1">
                <div class="logo-section" data-section="top-left"></div>
              </div>
              <div class="mosaic-piece grid-piece-2">
                <div class="logo-section" data-section="top-right"></div>
              </div>
              <div class="mosaic-piece grid-piece-3">
                <div class="logo-section" data-section="bottom-left"></div>
              </div>
              <div class="mosaic-piece grid-piece-4">
                <div class="logo-section" data-section="bottom-right"></div>
              </div>
            </div>
            <div class="story-info">
              <div class="story-meta">
                <span class="story-category">Analytics</span>
                <span class="story-date">Dec 8, 2024</span>
              </div>
              <h3 class="story-title">Data-Driven Decision Making</h3>
              <p class="story-excerpt">Leveraging advanced analytics to transform raw data into actionable business intelligence and strategic insights.</p>
              <a href="#" class="story-link">Read More</a>
            </div>
          </article>

          <!-- Story 3 - 6-Piece Complex -->
          <article class="news-story group">
            <div class="story-image-mosaic layout-6piece">
              <div class="mosaic-piece hex-piece-1">
                <div class="logo-section" data-section="hex-1"></div>
              </div>
              <div class="mosaic-piece hex-piece-2">
                <div class="logo-section" data-section="hex-2"></div>
              </div>
              <div class="mosaic-piece hex-piece-3">
                <div class="logo-section" data-section="hex-3"></div>
              </div>
              <div class="mosaic-piece hex-piece-4">
                <div class="logo-section" data-section="hex-4"></div>
              </div>
              <div class="mosaic-piece hex-piece-5">
                <div class="logo-section" data-section="hex-5"></div>
              </div>
              <div class="mosaic-piece hex-piece-6">
                <div class="logo-section" data-section="hex-6"></div>
              </div>
            </div>
            <div class="story-info">
              <div class="story-meta">
                <span class="story-category">Integration</span>
                <span class="story-date">Dec 5, 2024</span>
              </div>
              <h3 class="story-title">Seamless System Integration</h3>
              <p class="story-excerpt">Building robust API ecosystems that enable seamless data flow and communication between diverse platforms.</p>
              <a href="#" class="story-link">Read More</a>
            </div>
          </article>

          <!-- Story 4 - 5-Piece Puzzle -->
          <article class="news-story group">
            <div class="story-image-mosaic layout-5piece">
              <div class="mosaic-piece puzzle-piece-1">
                <div class="logo-section" data-section="puzzle-1"></div>
              </div>
              <div class="mosaic-piece puzzle-piece-2">
                <div class="logo-section" data-section="puzzle-2"></div>
              </div>
              <div class="mosaic-piece puzzle-piece-3">
                <div class="logo-section" data-section="puzzle-3"></div>
              </div>
              <div class="mosaic-piece puzzle-piece-4">
                <div class="logo-section" data-section="puzzle-4"></div>
              </div>
              <div class="mosaic-piece puzzle-piece-5">
                <div class="logo-section" data-section="puzzle-5"></div>
              </div>
            </div>
            <div class="story-info">
              <div class="story-meta">
                <span class="story-category">Design</span>
                <span class="story-date">Dec 3, 2024</span>
              </div>
              <h3 class="story-title">User Experience Excellence</h3>
              <p class="story-excerpt">Creating intuitive and engaging digital experiences that drive user satisfaction and business success.</p>
              <a href="#" class="story-link">Read More</a>
            </div>
          </article>

          <!-- Story 5 - 9-Piece Grid -->
          <article class="news-story group">
            <div class="story-image-mosaic layout-9piece">
              <div class="mosaic-piece nine-piece-1">
                <div class="logo-section" data-section="nine-1"></div>
              </div>
              <div class="mosaic-piece nine-piece-2">
                <div class="logo-section" data-section="nine-2"></div>
              </div>
              <div class="mosaic-piece nine-piece-3">
                <div class="logo-section" data-section="nine-3"></div>
              </div>
              <div class="mosaic-piece nine-piece-4">
                <div class="logo-section" data-section="nine-4"></div>
              </div>
              <div class="mosaic-piece nine-piece-5">
                <div class="logo-section" data-section="nine-5"></div>
              </div>
              <div class="mosaic-piece nine-piece-6">
                <div class="logo-section" data-section="nine-6"></div>
              </div>
              <div class="mosaic-piece nine-piece-7">
                <div class="logo-section" data-section="nine-7"></div>
              </div>
              <div class="mosaic-piece nine-piece-8">
                <div class="logo-section" data-section="nine-8"></div>
              </div>
              <div class="mosaic-piece nine-piece-9">
                <div class="logo-section" data-section="nine-9"></div>
              </div>
            </div>
            <div class="story-info">
              <div class="story-meta">
                <span class="story-category">Security</span>
                <span class="story-date">Dec 1, 2024</span>
              </div>
              <h3 class="story-title">Cybersecurity in the Digital Age</h3>
              <p class="story-excerpt">Advanced security frameworks protecting digital assets and ensuring compliance in an evolving threat landscape.</p>
              <a href="#" class="story-link">Read More</a>
            </div>
          </article>

          <!-- Story 6 - 7-Piece Asymmetric -->
          <article class="news-story group">
            <div class="story-image-mosaic layout-7piece">
              <div class="mosaic-piece asym-piece-1">
                <div class="logo-section" data-section="asym-1"></div>
              </div>
              <div class="mosaic-piece asym-piece-2">
                <div class="logo-section" data-section="asym-2"></div>
              </div>
              <div class="mosaic-piece asym-piece-3">
                <div class="logo-section" data-section="asym-3"></div>
              </div>
              <div class="mosaic-piece asym-piece-4">
                <div class="logo-section" data-section="asym-4"></div>
              </div>
              <div class="mosaic-piece asym-piece-5">
                <div class="logo-section" data-section="asym-5"></div>
              </div>
              <div class="mosaic-piece asym-piece-6">
                <div class="logo-section" data-section="asym-6"></div>
              </div>
              <div class="mosaic-piece asym-piece-7">
                <div class="logo-section" data-section="asym-7"></div>
              </div>
            </div>
            <div class="story-info">
              <div class="story-meta">
                <span class="story-category">Mobile</span>
                <span class="story-date">Nov 28, 2024</span>
              </div>
              <h3 class="story-title">Mobile-First Development</h3>
              <p class="story-excerpt">Embracing mobile-first strategies to deliver exceptional user experiences across all devices and platforms.</p>
              <a href="#" class="story-link">Read More</a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* Featured Story Styles */
  .featured-story-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .featured-story {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
    border-radius: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(10px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 400px;
  }

  .featured-story:hover {
    transform: translateY(-8px);
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 25px 50px -12px rgba(59, 130, 246, 0.25);
  }

  .story-image-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 0;
    position: relative;
    overflow: hidden;
  }

  .image-box {
    position: relative;
    overflow: hidden;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-box:nth-child(1) { 
    background: linear-gradient(45deg, #ff6b6b, #ee5a52);
    transform: translateX(-20px) translateY(-20px);
  }
  .image-box:nth-child(2) { 
    background: linear-gradient(45deg, #4ecdc4, #44a08d);
    transform: translateX(20px) translateY(-20px);
  }
  .image-box:nth-child(3) { 
    background: linear-gradient(45deg, #45b7d1, #96c93d);
    transform: translateX(-20px) translateY(20px);
  }
  .image-box:nth-child(4) { 
    background: linear-gradient(45deg, #f093fb, #f5576c);
    transform: translateX(20px) translateY(20px);
  }

  .featured-story:hover .image-box {
    transform: translateX(0) translateY(0);
  }

  .featured-story:hover .image-box:nth-child(1) { 
    animation: slideIn1 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .featured-story:hover .image-box:nth-child(2) { 
    animation: slideIn2 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.1s forwards;
  }
  .featured-story:hover .image-box:nth-child(3) { 
    animation: slideIn3 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.2s forwards;
  }
  .featured-story:hover .image-box:nth-child(4) { 
    animation: slideIn4 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.3s forwards;
  }

  @keyframes slideIn1 {
    from { transform: translateX(-20px) translateY(-20px); }
    to { transform: translateX(0) translateY(0); }
  }
  @keyframes slideIn2 {
    from { transform: translateX(20px) translateY(-20px); }
    to { transform: translateX(0) translateY(0); }
  }
  @keyframes slideIn3 {
    from { transform: translateX(-20px) translateY(20px); }
    to { transform: translateX(0) translateY(0); }
  }
  @keyframes slideIn4 {
    from { transform: translateX(20px) translateY(20px); }
    to { transform: translateX(0) translateY(0); }
  }

  .image-placeholder {
    font-size: 2rem;
    font-weight: 900;
    color: white;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    letter-spacing: 2px;
  }

  .story-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .story-content {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .story-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .story-category {
    background: rgba(59, 130, 246, 0.2);
    color: #60a5fa;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .story-date {
    color: #94a3b8;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
  }

  .story-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .story-excerpt {
    font-size: 1.125rem;
    color: #cbd5e1;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .story-link {
    color: #60a5fa;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .story-link:hover {
    color: #93c5fd;
    transform: translateX(4px);
  }

  .story-link::after {
    content: '→';
    transition: transform 0.3s ease;
  }

  .story-link:hover::after {
    transform: translateX(4px);
  }

  /* News Grid Styles */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
  }

  .news-story {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.6) 0%, rgba(15, 23, 42, 0.8) 100%);
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(8px);
  }

  .news-story:hover {
    transform: translateY(-6px);
    border-color: rgba(59, 130, 246, 0.3);
    box-shadow: 0 20px 40px -12px rgba(59, 130, 246, 0.2);
  }

  .story-image-mosaic {
    height: 200px;
    position: relative;
    overflow: hidden;
  }

  .mosaic-piece {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    font-weight: 900;
    color: white;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
    font-size: 1.2rem;
    letter-spacing: 1px;
  }

  /* Base Logo Section Styles */
  .logo-section {
    width: 100% !important;
    height: 100% !important;
    background-image: url('/images/user-sailing-girl.jpg') !important;
    background-repeat: no-repeat !important;
    position: relative !important;
    /* DEBUG: Add visible borders and minimum dimensions */
    border: 10px solid red !important;
    outline: 5px solid orange !important;
    min-height: 100px !important;
    min-width: 100px !important;
    box-shadow: inset 0 0 20px red !important;
  }
  
  /* DEBUG: Ensure parent containers have dimensions */
  .mosaic-piece {
    border: 5px solid blue !important;
    min-height: 150px !important;
    display: flex !important;
    align-items: stretch !important;
    justify-content: stretch !important;
  }
  
  .story-image-mosaic {
    border: 8px solid purple !important;
    min-height: 400px !important;
    background-color: orange !important;
    position: relative !important;
  }

  /* Layout 1: 3-Piece Vertical Split */
  .layout-3piece {
    display: grid;
    grid-template-rows: 1fr 1fr 1fr;
    gap: 0px;
    height: 400px;
    position: relative;
  }

  .split-piece-1 {
    grid-row: 1;
    transform: translateX(-200px) translateY(-50px) rotate(-5deg);
    opacity: 0.8;
  }

  .split-piece-2 {
    grid-row: 2;
    transform: translateX(150px) translateY(30px) rotate(3deg);
    opacity: 0.8;
  }

  .split-piece-3 {
    grid-row: 3;
    transform: translateX(-100px) translateY(80px) rotate(-2deg);
    opacity: 0.8;
  }

  .layout-3piece .logo-section[data-section="top"] {
    background-position: 50% 0% !important;
    background-size: 100% 300% !important;
  }

  .layout-3piece .logo-section[data-section="middle"] {
    background-position: 50% 50% !important;
    background-size: 100% 300% !important;
  }

  .layout-3piece .logo-section[data-section="bottom"] {
    background-position: 50% 100% !important;
    background-size: 100% 300% !important;
  }

  .layout-3piece:hover .split-piece-1 {
    transform: translateX(0) translateY(0) rotate(0deg);
    opacity: 1;
    grid-row: 1;
  }
  .layout-3piece:hover .split-piece-2 {
    transform: translateX(0) translateY(0) rotate(0deg);
    opacity: 1;
    grid-row: 2;
  }
  .layout-3piece:hover .split-piece-3 {
    transform: translateX(0) translateY(0) rotate(0deg);
    opacity: 1;
    grid-row: 3;
  }

  /* Layout 2: 4-Piece Grid */
  .layout-4piece {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 2px;
  }

  .grid-piece-1 { transform: translateX(-100px) translateY(-100px); }
  .grid-piece-2 { transform: translateX(100px) translateY(-100px); }
  .grid-piece-3 { transform: translateX(-100px) translateY(100px); }
  .grid-piece-4 { transform: translateX(100px) translateY(100px); }

  .layout-4piece .logo-section[data-section="top-left"] {
    background-position: 0 0;
    background-size: 200% 200%;
    background-color: red !important;
  }

  .layout-4piece .logo-section[data-section="top-right"] {
    background-position: -50% 0;
    background-size: 200% 200%;
    background-color: blue !important;
  }

  .layout-4piece .logo-section[data-section="bottom-left"] {
    background-position: 0 -50%;
    background-size: 200% 200%;
    background-color: green !important;
  }

  .layout-4piece .logo-section[data-section="bottom-right"] {
    background-position: -50% -50%;
    background-size: 200% 200%;
    background-color: purple !important;
  }

  .layout-4piece:hover .grid-piece-1,
  .layout-4piece:hover .grid-piece-2,
  .layout-4piece:hover .grid-piece-3,
  .layout-4piece:hover .grid-piece-4 {
    transform: translateX(0) translateY(0);
  }

  /* Layout 3: 6-Piece Complex */
  .layout-6piece {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 1fr 1fr;
    gap: 2px;
  }

  .hex-piece-1 { transform: translateY(-120px) rotate(15deg); }
  .hex-piece-2 { transform: translateY(-120px) rotate(-15deg); }
  .hex-piece-3 { transform: translateX(120px) rotate(15deg); }
  .hex-piece-4 { transform: translateY(120px) rotate(-15deg); }
  .hex-piece-5 { transform: translateY(120px) rotate(15deg); }
  .hex-piece-6 { transform: translateX(-120px) rotate(-15deg); }

  .layout-6piece .logo-section[data-section="hex-1"] {
    background-position: 0 0;
    background-size: 300% 200%;
  }

  .layout-6piece .logo-section[data-section="hex-2"] {
    background-position: -100% 0;
    background-size: 300% 200%;
  }

  .layout-6piece .logo-section[data-section="hex-3"] {
    background-position: -200% 0;
    background-size: 300% 200%;
  }

  .layout-6piece .logo-section[data-section="hex-4"] {
    background-position: 0 -100%;
    background-size: 300% 200%;
  }

  .layout-6piece .logo-section[data-section="hex-5"] {
    background-position: -100% -100%;
    background-size: 300% 200%;
  }

  .layout-6piece .logo-section[data-section="hex-6"] {
    background-position: -200% -100%;
    background-size: 300% 200%;
  }

  .layout-6piece:hover .hex-piece-1,
  .layout-6piece:hover .hex-piece-2,
  .layout-6piece:hover .hex-piece-3,
  .layout-6piece:hover .hex-piece-4,
  .layout-6piece:hover .hex-piece-5,
  .layout-6piece:hover .hex-piece-6 {
    transform: translateX(0) translateY(0) rotate(0deg);
  }

  /* Layout 4: 5-Piece Puzzle */
  .layout-5piece {
    display: grid;
    grid-template-columns: 2fr 1fr 2fr;
    grid-template-rows: 1fr 1fr;
    gap: 2px;
  }

  .puzzle-piece-1 { 
    grid-column: 1;
    transform: translateX(-150px) rotate(-20deg); 
  }
  .puzzle-piece-2 { 
    grid-column: 2;
    grid-row: span 2;
    transform: translateY(-100px) rotate(10deg); 
  }
  .puzzle-piece-3 { 
    grid-column: 3;
    transform: translateX(150px) rotate(20deg); 
  }
  .puzzle-piece-4 { 
    grid-column: 1;
    transform: translateX(-150px) rotate(15deg); 
  }
  .puzzle-piece-5 { 
    grid-column: 3;
    transform: translateX(150px) rotate(-15deg); 
  }

  .layout-5piece .logo-section[data-section="puzzle-1"] {
    background-position: 0 0;
    background-size: 250% 200%;
  }

  .layout-5piece .logo-section[data-section="puzzle-2"] {
