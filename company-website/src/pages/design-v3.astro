---
// Design V3: Editorial Craft
// White, gold accents, serif headlines. Playfair Display + Source Sans 3. Magazine editorial.
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DTP — Editorial Craft Concept</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="ec-body">
  <!-- Navigation -->
  <nav class="ec-nav">
    <div class="ec-container ec-nav-inner">
      <a href="/design-v3" class="ec-logo">Digital Technology Partner</a>
      <div class="ec-nav-links">
        <a href="/design-v3">Home</a>
        <a href="#approach">Approach</a>
        <a href="#work">Work</a>
        <a href="#faq">FAQ</a>
        <a href="#contact">Contact</a>
      </div>
      <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="ec-btn ec-btn-dark ec-nav-cta">Book a Call</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="ec-hero">
    <div class="ec-container ec-hero-grid">
      <div class="ec-hero-content">
        <div class="ec-hero-rule"></div>
        <h1>Artificial intelligence,<br/><em>simplified.</em></h1>
        <p class="ec-hero-sub">We cut through the hype, build AI that delivers, and prove value through real results — fast, focused, and tailored to you.</p>
        <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="ec-link-cta">Book a discovery call <span>→</span></a>
      </div>
      <div class="ec-hero-aside">
        <div class="ec-hero-badge">
          <span class="ec-badge-num">5</span>
          <span class="ec-badge-label">Stage<br/>Process</span>
        </div>
        <p class="ec-hero-location">Aberdeen, Scotland</p>
      </div>
    </div>
  </section>

  <!-- Gold Divider -->
  <div class="ec-divider"><div class="ec-divider-line"></div></div>

  <!-- Benefits -->
  <section class="ec-section" id="benefits">
    <div class="ec-container">
      <div class="ec-section-header">
        <span class="ec-label">Why Us</span>
        <h2>What sets our work apart</h2>
      </div>
      <div class="ec-benefits-grid">
        <div class="ec-benefit">
          <h3>Reduced Risk</h3>
          <p>We deliver in stages. You see progress early and avoid big-bang surprises.</p>
        </div>
        <div class="ec-benefit">
          <h3>Security by Design</h3>
          <p>Data protection and access controls are built in from day one.</p>
        </div>
        <div class="ec-benefit">
          <h3>Reliable Delivery</h3>
          <p>Clear scope, fixed steps, and regular check-ins keep work on track.</p>
        </div>
        <div class="ec-benefit">
          <h3>Scales with You</h3>
          <p>Start small, prove value, then roll out without rework.</p>
        </div>
        <div class="ec-benefit">
          <h3>Flexible Engagement</h3>
          <p>On your stack, in our cloud, or a hybrid — whatever fits policy and cost.</p>
        </div>
        <div class="ec-benefit">
          <h3>Works With Your Tools</h3>
          <p>We integrate with common meeting, messaging, and project platforms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="ec-section ec-section-dark">
    <div class="ec-container ec-testimonial">
      <blockquote>
        <p>"DTP understood our problem within the first meeting. The staged approach meant we could prove value to the board before committing to a full rollout."</p>
      </blockquote>
      <cite>Operations Director — Manufacturing Sector</cite>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="ec-section" id="approach">
    <div class="ec-container">
      <div class="ec-section-header">
        <span class="ec-label">Services</span>
        <h2>What we're asked to fix most often</h2>
      </div>
      <div class="ec-use-cases">
        <article class="ec-use-article">
          <span class="ec-use-num">01</span>
          <div class="ec-use-body">
            <h3>Operations Automation</h3>
            <p>Remove manual steps, reduce errors, and speed up routine work with intelligent process automation.</p>
          </div>
        </article>
        <article class="ec-use-article">
          <span class="ec-use-num">02</span>
          <div class="ec-use-body">
            <h3>Data &amp; Reporting</h3>
            <p>Bring data together and give teams clear dashboards, alerts, and actionable insights.</p>
          </div>
        </article>
        <article class="ec-use-article">
          <span class="ec-use-num">03</span>
          <div class="ec-use-body">
            <h3>AI Assistants for Teams</h3>
            <p>Turn meetings and messages into organised tasks, updates, and automated workflows.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="ec-divider"><div class="ec-divider-line"></div></div>

  <!-- Process -->
  <section class="ec-section" id="process">
    <div class="ec-container">
      <div class="ec-section-header">
        <span class="ec-label">Process</span>
        <h2>Five stages from idea to launch</h2>
      </div>
      <div class="ec-process-grid">
        <div class="ec-process-item">
          <div class="ec-process-marker">I</div>
          <h3>Discovery</h3>
          <p>Understand your challenge, map processes, identify the highest-value opportunity.</p>
        </div>
        <div class="ec-process-item">
          <div class="ec-process-marker">II</div>
          <h3>Proof of Concept</h3>
          <p>Build a focused prototype to validate the approach and demonstrate feasibility.</p>
        </div>
        <div class="ec-process-item">
          <div class="ec-process-marker">III</div>
          <h3>MVP</h3>
          <p>Develop a working product with core features ready for real-world testing.</p>
        </div>
        <div class="ec-process-item">
          <div class="ec-process-marker">IV</div>
          <h3>Pilot</h3>
          <p>Deploy with a controlled group, gather feedback, and refine before wider rollout.</p>
        </div>
        <div class="ec-process-item">
          <div class="ec-process-marker">V</div>
          <h3>Full Launch</h3>
          <p>Scale to production with monitoring, support, and continuous improvement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="ec-section ec-section-light" id="work">
    <div class="ec-container">
      <div class="ec-section-header">
        <span class="ec-label">Case Studies</span>
        <h2>Recent work</h2>
      </div>
      <div class="ec-cases">
        <article class="ec-case">
          <div class="ec-case-meta">
            <span class="ec-case-sector">Manufacturing</span>
            <span class="ec-case-divider">|</span>
            <span class="ec-case-impact">Hours → Minutes</span>
          </div>
          <h3>Automating Surface Area Calculations for Protective Coatings</h3>
          <p>Transformed hours of manual PDF analysis into minutes with 100% calculation accuracy. OCR-enabled tagging interface with automated Excel report generation.</p>
        </article>
        <article class="ec-case">
          <div class="ec-case-meta">
            <span class="ec-case-sector">Manufacturing</span>
            <span class="ec-case-divider">|</span>
            <span class="ec-case-impact">Zero Missed Tasks</span>
          </div>
          <h3>Intelligent Maintenance Management via Mobile Messaging</h3>
          <p>Messaging-native AI agent for production floor engineers. Natural language processing, voice notes, and photo capture — no training required.</p>
        </article>
        <article class="ec-case">
          <div class="ec-case-meta">
            <span class="ec-case-sector">Infrastructure</span>
            <span class="ec-case-divider">|</span>
            <span class="ec-case-impact">Accelerated Delivery</span>
          </div>
          <h3>AI/ML Expertise as Technical Subcontractor</h3>
          <p>Delivered vector database architecture, ML pipelines, and conversational AI within a consultancy's infrastructure monitoring project.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="ec-section" id="faq">
    <div class="ec-container ec-faq-wrap">
      <div class="ec-section-header">
        <span class="ec-label">FAQ</span>
        <h2>Common questions</h2>
      </div>
      <div class="ec-faq-list">
        <details class="ec-faq-item">
          <summary>How long does a typical engagement take?</summary>
          <p>Discovery takes 1–2 weeks. A Proof of Concept typically follows in 4–6 weeks. The full timeline depends on scope, but our staged approach means you see results early.</p>
        </details>
        <details class="ec-faq-item">
          <summary>Do you work with existing systems?</summary>
          <p>Yes. We integrate with your current tools, platforms, and data sources. We're stack-agnostic and work with whatever fits your infrastructure and policies.</p>
        </details>
        <details class="ec-faq-item">
          <summary>What industries do you work with?</summary>
          <p>We've delivered solutions across manufacturing, infrastructure, energy, and professional services.</p>
        </details>
        <details class="ec-faq-item">
          <summary>How is pricing structured?</summary>
          <p>Each stage is priced independently so you can validate value before committing to the next. No big-bang contracts — you stay in control throughout.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="ec-cta" id="contact">
    <div class="ec-container ec-cta-inner">
      <div class="ec-cta-rule"></div>
      <h2>Ready to begin?</h2>
      <p>Book a free discovery call. We'll listen, assess fit, and outline next steps — no obligation.</p>
      <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="ec-btn ec-btn-dark ec-btn-lg">Book a Discovery Call</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="ec-footer">
    <div class="ec-container ec-footer-inner">
      <p>&copy; 2025 Digital Technology Partner. All Rights Reserved.</p>
      <div class="ec-footer-links">
        <a href="https://www.linkedin.com/company/dtp-ai/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:Info@digitaltechnologypartner.ai">Email</a>
        <a href="https://wa.me/447769386204">WhatsApp</a>
      </div>
    </div>
  </footer>

  <!-- Variant Badge -->
  <div class="ec-variant-badge">
    V3: Editorial Craft
    <a href="/design-v2">← Prev</a>
    <a href="/design-v4">Next →</a>
  </div>
</body>
</html>

<style is:global>
  /* ========== V3: EDITORIAL CRAFT ========== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ec-white: #FFFFFF;
    --ec-off-white: #F9FAFB;
    --ec-black: #111111;
    --ec-gold: #C9A84C;
    --ec-gold-dim: rgba(201, 168, 76, 0.12);
    --ec-grey: #6B7280;
    --ec-light-grey: #E5E7EB;
    --ec-dark: #1C1917;
    --ec-font-display: 'Playfair Display', Georgia, serif;
    --ec-font-body: 'Source Sans 3', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  .ec-body {
    font-family: var(--ec-font-body);
    color: var(--ec-black);
    background: var(--ec-white);
    line-height: 1.7;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  .ec-container { max-width: 1120px; margin: 0 auto; padding: 0 2rem; }

  /* --- NAV --- */
  .ec-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ec-light-grey);
  }

  .ec-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .ec-logo {
    font-family: var(--ec-font-display);
    font-size: 1.15rem;
    color: var(--ec-black);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .ec-nav-links { display: flex; gap: 2.5rem; }

  .ec-nav-links a {
    font-size: 0.88rem;
    font-weight: 400;
    color: var(--ec-grey);
    text-decoration: none;
    transition: color 200ms ease;
    letter-spacing: 0.02em;
  }

  .ec-nav-links a:hover { color: var(--ec-black); }

  .ec-nav-cta { font-size: 0.82rem !important; padding: 0.5rem 1.2rem !important; }

  /* --- BUTTONS --- */
  .ec-btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--ec-font-body);
    font-weight: 600;
    font-size: 0.92rem;
    padding: 0.8rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 250ms cubic-bezier(0.4, 0, 0.2, 1);
    letter-spacing: 0.02em;
  }

  .ec-btn-dark {
    background: var(--ec-black);
    color: var(--ec-white);
  }

  .ec-btn-dark:hover {
    background: #2A2A2A;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(17, 17, 17, 0.2);
  }

  .ec-btn-lg { font-size: 1rem; padding: 1rem 2.25rem; }

  .ec-link-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--ec-font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--ec-black);
    text-decoration: none;
    border-bottom: 2px solid var(--ec-gold);
    padding-bottom: 0.25rem;
    transition: all 200ms ease;
  }

  .ec-link-cta:hover { color: var(--ec-gold); }

  .ec-link-cta span {
    transition: transform 200ms ease;
  }

  .ec-link-cta:hover span { transform: translateX(4px); }

  /* --- HERO --- */
  .ec-hero {
    padding: 12rem 0 7rem;
    background: var(--ec-white);
  }

  .ec-hero-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: end;
  }

  .ec-hero-rule {
    width: 48px;
    height: 3px;
    background: var(--ec-gold);
    margin-bottom: 2rem;
  }

  .ec-hero h1 {
    font-family: var(--ec-font-display);
    font-size: clamp(2.8rem, 5.5vw, 4.2rem);
    line-height: 1.15;
    color: var(--ec-black);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .ec-hero h1 em {
    font-style: italic;
    color: var(--ec-grey);
  }

  .ec-hero-sub {
    font-size: 1.1rem;
    color: var(--ec-grey);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .ec-hero-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2rem;
  }

  .ec-hero-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--ec-light-grey);
    border-radius: 4px;
  }

  .ec-badge-num {
    font-family: var(--ec-font-display);
    font-size: 2.5rem;
    color: var(--ec-gold);
    line-height: 1;
  }

  .ec-badge-label {
    font-size: 0.82rem;
    color: var(--ec-grey);
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ec-hero-location {
    font-size: 0.85rem;
    color: var(--ec-grey);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* --- DIVIDER --- */
  .ec-divider { padding: 0 2rem; }

  .ec-divider-line {
    max-width: 1120px;
    margin: 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ec-gold), transparent);
  }

  /* --- SECTIONS --- */
  .ec-section { padding: 6rem 0; }
  .ec-section-light { background: var(--ec-off-white); }
  .ec-section-dark { background: var(--ec-dark); }

  .ec-section-header { margin-bottom: 3.5rem; }

  .ec-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ec-gold);
    margin-bottom: 0.75rem;
  }

  .ec-section-header h2 {
    font-family: var(--ec-font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: var(--ec-black);
    letter-spacing: -0.01em;
  }

  .ec-section-dark .ec-section-header h2 { color: var(--ec-white); }

  /* --- BENEFITS --- */
  .ec-benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 3rem;
  }

  .ec-benefit {
    border-top: 1px solid var(--ec-light-grey);
    padding-top: 1.5rem;
  }

  .ec-benefit h3 {
    font-family: var(--ec-font-display);
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--ec-black);
  }

  .ec-benefit p { color: var(--ec-grey); font-size: 0.95rem; line-height: 1.65; }

  /* --- TESTIMONIAL --- */
  .ec-testimonial {
    max-width: 760px;
    text-align: center;
    padding: 3rem 0;
  }

  .ec-testimonial blockquote p {
    font-family: var(--ec-font-display);
    font-size: 1.6rem;
    line-height: 1.5;
    color: var(--ec-white);
    font-style: italic;
    margin-bottom: 1.25rem;
  }

  .ec-testimonial cite {
    font-style: normal;
    color: var(--ec-gold);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* --- USE CASES --- */
  .ec-use-cases {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ec-use-article {
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--ec-light-grey);
    transition: all 250ms ease;
  }

  .ec-use-article:first-child { border-top: 1px solid var(--ec-light-grey); }

  .ec-use-article:hover { padding-left: 1rem; }

  .ec-use-num {
    font-family: var(--ec-font-display);
    font-size: 2.5rem;
    color: var(--ec-gold);
    opacity: 0.35;
    min-width: 60px;
    line-height: 1;
  }

  .ec-use-body h3 {
    font-family: var(--ec-font-display);
    font-size: 1.3rem;
    color: var(--ec-black);
    margin-bottom: 0.5rem;
  }

  .ec-use-body p { color: var(--ec-grey); font-size: 0.95rem; }

  /* --- PROCESS --- */
  .ec-process-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
  }

  .ec-process-item {
    text-align: center;
    padding: 1.5rem 0.5rem;
    border-top: 2px solid var(--ec-light-grey);
    transition: all 250ms ease;
  }

  .ec-process-item:hover { border-top-color: var(--ec-gold); }

  .ec-process-marker {
    font-family: var(--ec-font-display);
    font-size: 1.8rem;
    color: var(--ec-gold);
    margin-bottom: 1rem;
  }

  .ec-process-item h3 {
    font-family: var(--ec-font-display);
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
    color: var(--ec-black);
  }

  .ec-process-item p {
    color: var(--ec-grey);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* --- CASES --- */
  .ec-cases {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .ec-case {
    padding: 2rem;
    border: 1px solid var(--ec-light-grey);
    border-radius: 4px;
    background: var(--ec-white);
    transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ec-case:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(17, 17, 17, 0.08);
  }

  .ec-case-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ec-case-sector { color: var(--ec-grey); font-weight: 600; }
  .ec-case-divider { color: var(--ec-light-grey); }
  .ec-case-impact { color: var(--ec-gold); font-weight: 600; }

  .ec-case h3 {
    font-family: var(--ec-font-display);
    font-size: 1.15rem;
    line-height: 1.35;
    margin-bottom: 0.75rem;
    color: var(--ec-black);
  }

  .ec-case p { color: var(--ec-grey); font-size: 0.9rem; }

  /* --- FAQ --- */
  .ec-faq-wrap { max-width: 720px; }

  .ec-faq-item {
    border-bottom: 1px solid var(--ec-light-grey);
    padding: 1.25rem 0;
  }

  .ec-faq-item summary {
    font-family: var(--ec-font-display);
    font-size: 1.1rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--ec-black);
    transition: color 200ms ease;
  }

  .ec-faq-item summary:hover { color: var(--ec-gold); }

  .ec-faq-item summary::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--ec-gold);
    transition: transform 200ms ease;
  }

  .ec-faq-item[open] summary::after { transform: rotate(45deg); }

  .ec-faq-item p {
    margin-top: 0.75rem;
    color: var(--ec-grey);
    font-size: 0.95rem;
    line-height: 1.7;
    padding-right: 2rem;
  }

  /* --- CTA --- */
  .ec-cta {
    padding: 6rem 0;
    background: var(--ec-off-white);
  }

  .ec-cta-inner {
    text-align: center;
    max-width: 560px;
  }

  .ec-cta-rule {
