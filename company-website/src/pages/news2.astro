---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Tech News Hub - Digital Technology Partner">
  <Header />
  <main>
    <!-- Hero -->
    <section class="ma-hero">
      <div class="ma-grid-bg"></div>
      <div class="ma-scan-line"></div>
      <div class="ma-container ma-hero-content">
        <div class="ma-hero-tag">// news</div>
        <h1>Tech News Hub<span class="ma-cursor">|</span></h1>
        <p class="ma-hero-sub">Stay ahead with the latest insights in digital transformation, AI, and emerging technologies.</p>
      </div>
    </section>

    <!-- News Content with Tag Sidebar -->
    <section class="ma-section">
      <div class="ma-container">
        <div class="news-layout">
          <!-- Tag Sidebar -->
          <aside class="news-sidebar">
            <h3>Browse by Tag</h3>
            <div class="news-tag-list" id="tag-filter">
              <button data-tag="all" class="news-tag-btn active">All</button>
              <button data-tag="featured" class="news-tag-btn">Featured</button>
              <button data-tag="ai" class="news-tag-btn">AI</button>
              <button data-tag="cloud" class="news-tag-btn">Cloud</button>
              <button data-tag="security" class="news-tag-btn">Security</button>
              <button data-tag="blockchain" class="news-tag-btn">Blockchain</button>
              <button data-tag="iot" class="news-tag-btn">IoT</button>
              <button data-tag="trends" class="news-tag-btn">Trends</button>
              <button data-tag="development" class="news-tag-btn">Development</button>
            </div>
          </aside>

          <!-- Articles -->
          <div class="news-content" id="news-content">
            <!-- Featured Article Grid -->
            <div class="news-featured-grid">
              <!-- Large Featured Article -->
              <article data-tags="featured,ai" class="news-card news-card-featured">
                <div class="ma-card-line"></div>
                <div class="news-card-inner">
                  <div>
                    <div class="news-card-meta">
                      <span class="ma-tag">Featured</span>
                      <span class="news-date">Dec 15, 2024</span>
                    </div>
                    <h2>The Future of AI in Enterprise: Beyond ChatGPT</h2>
                    <p class="news-excerpt-lg">Exploring how artificial intelligence is reshaping business operations, from automated decision-making to predictive analytics and the next generation of enterprise AI solutions.</p>
                  </div>
                  <div class="news-author">
                    <div class="news-author-avatar">AI</div>
                    <div>
                      <span class="news-author-name">Sarah Chen</span>
                      <span class="news-author-role">AI Research Lead</span>
                    </div>
                  </div>
                </div>
              </article>

              <!-- Medium Article -->
              <article data-tags="cloud,security" class="news-card">
                <div class="ma-card-line"></div>
                <div class="news-card-inner">
                  <div>
                    <div class="news-card-meta">
                      <span class="ma-tag">Cloud</span>
                      <span class="news-date">Dec 12, 2024</span>
                    </div>
                    <h3>Kubernetes Security: Best Practices for 2025</h3>
                    <p>Essential security measures every DevOps team should implement when deploying containerized applications.</p>
                  </div>
                  <span class="news-read-more">Read Article →</span>
                </div>
              </article>

              <!-- Small Article 1 -->
              <article data-tags="blockchain" class="news-card">
                <div class="ma-card-line"></div>
                <div class="news-card-inner">
                  <div>
                    <div class="news-card-meta">
                      <span class="ma-tag">Blockchain</span>
                    </div>
                    <h3>Web3 Integration Strategies</h3>
                    <p>How traditional businesses are adopting blockchain technology.</p>
                  </div>
                  <span class="news-date">Dec 10, 2024</span>
                </div>
              </article>

              <!-- Small Article 2 -->
              <article data-tags="iot" class="news-card">
                <div class="ma-card-line"></div>
                <div class="news-card-inner">
                  <div>
                    <div class="news-card-meta">
                      <span class="ma-tag">IoT</span>
                    </div>
                    <h3>Smart Manufacturing Revolution</h3>
                    <p>IoT sensors transforming production efficiency and quality control.</p>
                  </div>
                  <span class="news-date">Dec 8, 2024</span>
                </div>
              </article>
            </div>

            <!-- Secondary News Grid -->
            <div class="news-secondary-grid">
              <!-- Quantum Computing -->
              <article data-tags="trends,quantum" class="news-card">
                <div class="ma-card-line"></div>
                <div class="news-card-inner">
                  <div>
                    <div class="news-card-meta">
                      <span class="ma-tag">Trends</span>
                      <span class="news-date">Dec 5, 2024</span>
                    </div>
                    <h3>Quantum Computing Breakthroughs</h3>
                    <p>Recent advances in quantum processors and their potential impact on cryptography and complex problem solving.</p>
                  </div>
                  <div class="news-card-footer">
                    <span class="news-read-time">5 min read</span>
                    <span class="news-read-more">→</span>
                  </div>
                </div>
              </article>

              <!-- Next.js 15 -->
              <article data-tags="development,nextjs" class="news-card">
                <div class="ma-card-line"></div>
                <div class="news-card-inner">
                  <div>
                    <div class="news-card-meta">
                      <span class="ma-tag">Development</span>
                      <span class="news-date">Dec 3, 2024</span>
                    </div>
                    <h3>Next.js 15: What's New</h3>
                    <p>Exploring the latest features in Next.js 15, including improved performance and new developer tools.</p>
                  </div>
                  <div class="news-card-footer">
                    <span class="news-read-time">8 min read</span>
                    <span class="news-read-more">→</span>
                  </div>
                </div>
              </article>

              <!-- Zero Trust -->
              <article data-tags="security" class="news-card">
                <div class="ma-card-line"></div>
                <div class="news-card-inner">
                  <div>
                    <div class="news-card-meta">
                      <span class="ma-tag">Security</span>
                      <span class="news-date">Dec 1, 2024</span>
                    </div>
                    <h3>Zero Trust Architecture</h3>
                    <p>Implementing zero trust security models in modern enterprise environments for enhanced protection.</p>
                  </div>
                  <div class="news-card-footer">
                    <span class="news-read-time">6 min read</span>
                    <span class="news-read-more">→</span>
                  </div>
                </div>
              </article>
            </div>

            <!-- Newsletter Subscription -->
            <div class="news-newsletter">
              <h3>Stay Updated</h3>
              <p>Get the latest tech insights, industry trends, and digital transformation strategies delivered to your inbox.</p>
              <div class="news-newsletter-form">
                <input type="email" placeholder="Enter your email" class="news-newsletter-input" />
                <button class="ma-btn ma-btn-mint">Subscribe</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* --- Hero --- */
  .ma-hero {
    position: relative;
    padding: 11rem 0 6rem;
    overflow: hidden;
  }
  .ma-hero-content { position: relative; z-index: 2; max-width: 720px; }
  .ma-hero-tag {
    font-family: var(--ma-font-mono);
    font-size: 0.85rem;
    color: var(--ma-mint);
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }
  .ma-hero h1 { line-height: 1.05; margin-bottom: 1.5rem; letter-spacing: -0.03em; }
  .ma-hero-sub {
    font-size: 1.1rem;
    color: var(--ma-text-dim);
    max-width: 560px;
    line-height: 1.7;
  }

  /* --- News Layout --- */
  .news-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* --- Tag Sidebar --- */
  .news-sidebar {
    position: sticky;
    top: 6rem;
    background: var(--ma-surface);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius-lg);
    padding: 1.5rem;
  }
  .news-sidebar h3 {
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .news-tag-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .news-tag-btn {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.45rem 0.75rem;
    font-family: var(--ma-font-body);
    font-size: 0.82rem;
    color: var(--ma-text-dim);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--ma-radius);
    cursor: pointer;
    transition: all var(--ma-transition);
  }
  .news-tag-btn:hover {
    color: var(--ma-text);
    background: rgba(255, 255, 255, 0.03);
    border-color: var(--ma-border);
  }
  .news-tag-btn.active {
    color: var(--ma-mint);
    background: var(--ma-mint-dim);
    border-color: rgba(0, 229, 160, 0.25);
  }

  /* --- News Content Area --- */
  .news-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* --- Featured Grid: 1 large + 3 smaller --- */
  .news-featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }
  .news-card-featured {
    grid-row: 1 / 3;
  }

  /* --- Secondary Grid: 3 equal --- */
  .news-secondary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* --- News Card --- */
  .news-card {
    background: var(--ma-surface);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius-lg);
    padding: 1.75rem;
    position: relative;
    overflow: hidden;
    transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .news-card:hover {
    border-color: var(--ma-mint);
    transform: translateY(-4px);
    box-shadow: 0 0 0 1px var(--ma-mint), 0 20px 40px rgba(0, 229, 160, 0.08);
  }
  .news-card:hover .ma-card-line { opacity: 1; }

  .news-card-inner {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }

  .news-card h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .news-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .news-card p {
    font-size: 0.88rem;
    color: var(--ma-text-dim);
    line-height: 1.65;
  }
  .news-excerpt-lg {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* --- Card Meta --- */
  .news-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .news-date {
    font-size: 0.78rem;
    color: var(--ma-text-dim);
  }

  /* --- Author Block --- */
  .news-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--ma-border);
  }
  .news-author-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ma-mint), rgba(0, 229, 160, 0.5));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--ma-font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ma-bg);
    flex-shrink: 0;
  }
  .news-author-name {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ma-white);
  }
  .news-author-role {
    display: block;
    font-size: 0.75rem;
    color: var(--ma-text-dim);
  }

  /* --- Card Footer --- */
  .news-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--ma-border);
  }
  .news-read-time {
    font-size: 0.78rem;
    color: var(--ma-mint);
    font-weight: 500;
  }
  .news-read-more {
    font-size: 0.85rem;
    color: var(--ma-mint);
    font-weight: 500;
    transition: all var(--ma-transition);
  }
  .news-card:hover .news-read-more {
    letter-spacing: 0.02em;
  }

  /* --- Newsletter --- */
  .news-newsletter {
    background: var(--ma-surface);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius-lg);
    padding: 3rem 2rem;
    text-align: center;
  }
  .news-newsletter h3 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
  }
  .news-newsletter > p {
    font-size: 0.92rem;
    color: var(--ma-text-dim);
    margin-bottom: 1.5rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.65;
  }
  .news-newsletter-form {
    display: flex;
    gap: 0.75rem;
    max-width: 400px;
    margin: 0 auto;
  }
  .news-newsletter-input {
    flex: 1;
    padding: 0.7rem 1rem;
    background: var(--ma-surface-alt);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius);
    color: var(--ma-text);
    font-family: var(--ma-font-body);
    font-size: 0.88rem;
    outline: none;
    transition: border-color var(--ma-transition);
  }
  .news-newsletter-input::placeholder {
    color: var(--ma-text-dim);
  }
  .news-newsletter-input:focus {
    border-color: var(--ma-mint);
  }

  /* --- Responsive --- */
  @media (max-width: 1024px) {
    .news-layout { grid-template-columns: 1fr; }
    .news-sidebar {
      position: static;
      padding: 1rem;
    }
    .news-tag-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.35rem;
    }
    .news-tag-btn {
      width: auto;
    }
  }
  @media (max-width: 768px) {
    .ma-hero { padding: 8rem 0 4rem; }
    .news-featured-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .news-card-featured { grid-row: auto; }
    .news-secondary-grid { grid-template-columns: 1fr; }
    .news-newsletter-form { flex-direction: column; }
  }
</style>

<script>
  // Tag-based filtering for news articles
  (function () {
    const tagContainer = document.getElementById('tag-filter');
    const newsContent = document.getElementById('news-content');
    if (!tagContainer || !newsContent) return;

    const allArticles = Array.from(newsContent.querySelectorAll('article'));
    const originalOrder = allArticles.slice();

    const tagSet = new Set();
    originalOrder.forEach((el) => {
      (el.getAttribute('data-tags') || '')
        .split(',')
        .map((t) => t.trim().toLowerCase())
        .filter(Boolean)
        .forEach((t) => tagSet.add(t));
    });

    tagContainer.innerHTML = '';
    const makeBtn = (text, tag, active = false) => {
      const b = document.createElement('button');
      b.textContent = text;
      b.setAttribute('data-tag', tag);
      b.className = 'news-tag-btn' + (active ? ' active' : '');
      return b;
    };
    tagContainer.appendChild(makeBtn('All', 'all', true));
    Array.from(tagSet)
      .sort((a, b) => a.localeCompare(b))
      .forEach((t) => tagContainer.appendChild(makeBtn(t.replace(/\b\w/g, (m) => m.toUpperCase()), t)));

    function applyActive(button) {
      tagContainer.querySelectorAll('.news-tag-btn').forEach((b) => b.classList.remove('active'));
      button.classList.add('active');
    }

    function filterByTag(tag) {
      allArticles.forEach((el) => {
        const tags = (el.getAttribute('data-tags') || '').toLowerCase();
        const match = tag === 'all' || tags.split(',').map((t) => t.trim()).includes(tag);
        el.style.display = match ? '' : 'none';
      });
    }

    tagContainer.addEventListener('click', (e) => {
      const btn = e.target.closest('.news-tag-btn');
      if (!btn) return;
      const tag = (btn.getAttribute('data-tag') || 'all').toLowerCase();
      applyActive(btn);
      filterByTag(tag);
    });
  })();
</script>
