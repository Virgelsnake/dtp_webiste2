---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="About Us - Digital Technology Partner">
  <Header />
  <main>
    <!-- Hero -->
    <section class="ma-hero">
      <div class="ma-grid-bg"></div>
      <div class="ma-scan-line"></div>
      <div class="ma-container ma-hero-content">
        <div class="ma-hero-tag">// about</div>
        <h1>About<span class="ma-cursor">|</span></h1>
        <p class="ma-hero-sub">Learn more about our company</p>
      </div>
    </section>

    <!-- Placeholder content area -->
    <section class="ma-section">
      <div class="ma-container about-center">
        <p class="about-note">We're a team of AI practitioners helping organisations turn ideas into working solutions — without the hype.</p>
      </div>
    </section>

    <!-- CTA -->
    <section class="ma-cta">
      <div class="ma-container ma-cta-inner">
        <h2>Want to know more?</h2>
        <p>Book a free discovery call and learn how we work.</p>
        <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="ma-btn ma-btn-mint ma-btn-lg">Book a Discovery Call</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* --- Hero --- */
  .ma-hero {
    position: relative;
    padding: 11rem 0 6rem;
    overflow: hidden;
  }
  .ma-hero-content { position: relative; z-index: 2; max-width: 720px; }
  .ma-hero-tag {
    font-family: var(--ma-font-mono);
    font-size: 0.85rem;
    color: var(--ma-mint);
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }
  .ma-hero h1 { line-height: 1.05; margin-bottom: 1.5rem; letter-spacing: -0.03em; }
  .ma-hero-sub {
    font-size: 1.1rem;
    color: var(--ma-text-dim);
    max-width: 560px;
    line-height: 1.7;
  }

  /* --- About Content --- */
  .about-center { max-width: 640px; text-align: center; }
  .about-note {
    font-size: 1.15rem;
    color: var(--ma-text);
    line-height: 1.7;
  }

  /* --- CTA --- */
  .ma-cta {
    padding: 6rem 0;
    background: linear-gradient(135deg, var(--ma-surface) 0%, var(--ma-bg) 100%);
    border-top: 1px solid var(--ma-border);
  }
  .ma-cta-inner { text-align: center; max-width: 600px; }
  .ma-cta-inner h2 { margin-bottom: 1rem; }
  .ma-cta-inner p { color: var(--ma-text-dim); margin-bottom: 2rem; font-size: 1.05rem; }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .ma-hero { padding: 8rem 0 4rem; }
  }
</style>
