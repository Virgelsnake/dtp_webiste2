    border-color: rgba(0, 229, 160, 0.3);
    transform: translateY(-3px);
  }
  .ma-testimonial-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, var(--ma-mint) 0%, rgba(0, 229, 160, 0.2) 100%);
    opacity: 0;
    transition: opacity 300ms ease;
  }
  .ma-testimonial-card:hover::before {
