  </main>
<script>
  // S11: Results Ticker - Count up/down animation for hero stats (simultaneous)
  document.addEventListener('DOMContentLoaded', () => {
    const statsSection = document.getElementById('hero-stats');
    if (!statsSection) return;
    
    const statValues = Array.from(statsSection.querySelectorAll('.ma-stat-val'));
    let hasAnimated = false;
    
    const animateStat = (el: HTMLElement) => {
      const start = parseInt(el.dataset['start'] || '0');
      const target = parseInt(el.dataset['target'] || '0');
      const suffix = el.dataset['suffix'] || '';
      const direction = el.dataset['direction'] || 'up';
      const duration = 1500; // ms
      const startTime = performance.now();
      
      const updateCount = (currentTime: number) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        
        // Ease out cubic
        const easeOut = 1 - Math.pow(1 - progress, 3);
        
        let current: number;
        if (direction === 'down') {
          // Count down from start to target
          current = Math.floor(start - (easeOut * (start - target)));
        } else {
          // Count up from start to target
          current = Math.floor(start + (easeOut * (target - start)));
        }
        
        el.textContent = current + suffix;
        
        if (progress < 1) {
          requestAnimationFrame(updateCount);
        } else {
          el.textContent = target + suffix;
        }
      };
      
      requestAnimationFrame(updateCount);
    };
    
    // Trigger on scroll into view - all animate simultaneously
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !hasAnimated) {
          hasAnimated = true;
          statValues.forEach(stat => {
            animateStat(stat as HTMLElement);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.5 });
    
    observer.observe(statsSection);
  });
</script>

<style>
  /* S11: Results ticker animation enhancement */
  .ma-stat-val {
    display: block;
    font-family: var(--ma-font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--ma-mint);
    transition: transform 0.3s ease;
  }
  
  .ma-stat-val.counting {
    transform: scale(1.05);
  }
</style>

<style>
  /* --- Hero --- */
  .ma-hero {
    position: relative;
    padding: 11rem 0 6rem;
    overflow: hidden;
  }

  /* --- HERO GRID BACKGROUND --- */
  .ma-hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--ma-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--ma-border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.15;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 40%, black, transparent);
  }

  .ma-hero-scan {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ma-mint), transparent);
    opacity: 0.5;
    animation: ma-scan 4s ease-in-out infinite;
  }

  @keyframes ma-scan {
    0% { top: 10%; opacity: 0; }
    10% { opacity: 0.5; }
    90% { opacity: 0.5; }
    100% { top: 95%; opacity: 0; }
  }
  .mesh-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: 
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(0, 229, 160, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(59, 130, 246, 0.1) 0%, transparent 50%),
      radial-gradient(ellipse 70% 60% at 60% 20%, rgba(139, 92, 246, 0.08) 0%, transparent 50%);
    animation: meshMoveHero 25s ease-in-out infinite;
    filter: blur(80px);
  }

  @keyframes meshMoveHero {
    0%, 100% {
      background-position: 0% 0%, 100% 100%, 50% 0%;
      transform: scale(1);
    }
    33% {
      background-position: 50% 50%, 50% 0%, 0% 100%;
      transform: scale(1.08);
    }
    66% {
      background-position: 100% 50%, 0% 50%, 50% 100%;
      transform: scale(1.15);
    }
  }

  .gradient-mesh-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: 
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(0, 229, 160, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse 70% 60% at 60% 20%, rgba(139, 92, 246, 0.05) 0%, transparent 50%);
    animation: meshMove 20s ease-in-out infinite;
    filter: blur(60px);
  }

  @keyframes meshMove {
    0%, 100% {
      background-position: 0% 0%, 100% 100%, 50% 0%;
      transform: scale(1);
    }
    33% {
      background-position: 50% 50%, 50% 0%, 0% 100%;
      transform: scale(1.05);
    }
    66% {
      background-position: 100% 50%, 0% 50%, 50% 100%;
      transform: scale(1.1);
    }
  }

  /* Testimonials Gradient Mesh */
  .mesh-testimonials {
    position: relative;
    overflow: hidden;
  }

  .mesh-testimonials-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: 
      radial-gradient(ellipse 70% 50% at 30% 30%, rgba(0, 229, 160, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 70% 70%, rgba(20, 184, 166, 0.04) 0%, transparent 50%);
    animation: meshMoveTestimonials 30s ease-in-out infinite;
    filter: blur(80px);
  }

  @keyframes meshMoveTestimonials {
    0%, 100% {
      background-position: 30% 30%, 70% 70%, 50% 50%;
      transform: scale(1);
    }
    25% {
      background-position: 60% 40%, 40% 80%, 30% 60%;
      transform: scale(1.08);
    }
    50% {
      background-position: 80% 60%, 20% 40%, 70% 30%;
      transform: scale(1.12);
    }
    75% {
      background-position: 40% 80%, 80% 20%, 20% 70%;
      transform: scale(1.06);
    }
  }

  .mesh-testimonials .ma-container {
    position: relative;
    z-index: 1;
  }
  .ma-hero-content { position: relative; z-index: 2; max-width: 720px; }
  .ma-hero-tag {
    font-family: var(--ma-font-mono);
    font-size: 0.85rem;
    color: var(--ma-mint);
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }
  .ma-hero h1 { line-height: 1.05; margin-bottom: 1.5rem; letter-spacing: -0.03em; }
  .ma-hero-sub {
    font-size: 1.1rem;
    color: var(--ma-text-dim);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }
  .ma-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 4rem; }
  .ma-hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--ma-border);
  }
  .ma-stat-val {
    display: block;
    font-family: var(--ma-font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--ma-mint);
  }
  .ma-stat-label {
    font-size: 0.8rem;
    color: var(--ma-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .ma-stat-divider {
    width: 1px;
    height: 40px;
    background: var(--ma-border);
  }

  /* --- Benefits Grid (Simplified for Cognitive Fluency) --- */
  .ma-benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .ma-benefit-card {
