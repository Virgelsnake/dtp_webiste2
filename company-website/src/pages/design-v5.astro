          <div class="cg-case-stack">
            <span>AI Agent</span><span>NLP</span><span>Cloud APIs</span><span>Mobile</span><span>Voice</span>
          </div>
        </div>
        <div class="cg-case">
          <div class="cg-case-top">
            <span class="cg-case-tag">Infrastructure</span>
