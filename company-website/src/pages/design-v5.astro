<style is:global>
  /* ========== V5: CLEAN GEOMETRY ========== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cg-white: #F8F9FA;
    --cg-pure-white: #FFFFFF;
    --cg-navy: #0F172A;
    --cg-navy-light: #1E293B;
    --cg-blue: #3B82F6;
    --cg-blue-dim: rgba(59, 130, 246, 0.08);
    --cg-blue-glow: rgba(59, 130, 246, 0.15);
    --cg-border: #E2E8F0;
    --cg-light: #F1F5F9;
    --cg-text: #0F172A;
    --cg-text-dim: #64748B;
    --cg-font-display: 'General Sans', system-ui, sans-serif;
    --cg-font-body: 'Inter Tight', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  .cg-body {
    font-family: var(--cg-font-body);
    color: var(--cg-text);
    background: var(--cg-white);
    line-height: 1.65;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  .cg-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  /* --- NAV --- */
  .cg-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(248, 249, 250, 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--cg-border);
  }

  .cg-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .cg-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }

  .cg-logo span {
    font-family: var(--cg-font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--cg-navy);
    letter-spacing: -0.02em;
  }

  .cg-nav-links { display: flex; gap: 2rem; }

  .cg-nav-links a {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--cg-text-dim);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .cg-nav-links a:hover { color: var(--cg-blue); }

  .cg-nav-cta { font-size: 0.82rem !important; padding: 0.45rem 1.1rem !important; }

  /* --- BUTTONS --- */
  .cg-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--cg-font-display);
    font-weight: 600;
    font-size: 0.92rem;
    padding: 0.8rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cg-btn-primary {
    background: var(--cg-blue);
    color: white;
    box-shadow: 0 1px 3px rgba(59, 130, 246, 0.2);
  }

  .cg-btn-primary:hover {
    background: #2563EB;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.3);
  }

  .cg-btn-secondary {
    background: var(--cg-pure-white);
    color: var(--cg-navy);
    border: 1.5px solid var(--cg-border);
  }

  .cg-btn-secondary:hover {
    border-color: var(--cg-blue);
    color: var(--cg-blue);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
  }

  .cg-btn-lg { font-size: 1rem; padding: 0.95rem 2rem; }

  /* --- HERO --- */
  .cg-hero {
    position: relative;
    padding: 11rem 0 7rem;
    background: var(--cg-white);
    overflow: hidden;
  }

  .cg-hero-geo {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cg-geo-circle {
    position: absolute;
    border-radius: 50%;
    border: 1px solid var(--cg-border);
  }

  .cg-geo-1 {
    width: 500px;
    height: 500px;
    top: -100px;
    right: -100px;
    animation: cg-spin 40s linear infinite;
  }

  .cg-geo-2 {
    width: 300px;
    height: 300px;
    top: 0px;
    right: 0px;
    border-color: var(--cg-blue-glow);
    animation: cg-spin 30s linear infinite reverse;
  }

  .cg-geo-line {
    position: absolute;
    background: var(--cg-border);
  }

  .cg-line-1 {
    width: 1px;
    height: 200px;
    bottom: 0;
    right: 20%;
    opacity: 0.5;
  }

  .cg-line-2 {
    width: 200px;
    height: 1px;
    bottom: 30%;
    right: 0;
    opacity: 0.3;
  }

  @keyframes cg-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .cg-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .cg-pill {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--cg-blue);
    background: var(--cg-blue-dim);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    margin-bottom: 1.75rem;
  }

  .cg-hero h1 {
    font-family: var(--cg-font-display);
    font-size: clamp(2.8rem, 6vw, 4.2rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--cg-navy);
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .cg-hero-sub {
    font-size: 1.1rem;
    color: var(--cg-text-dim);
    max-width: 540px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .cg-hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* --- SECTIONS --- */
  .cg-section { padding: 6rem 0; }
  .cg-section-white { background: var(--cg-pure-white); }
  .cg-section-light { background: var(--cg-light); }
  .cg-section-navy { background: var(--cg-navy); }

  .cg-section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .cg-section-header h2 {
    font-family: var(--cg-font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: var(--cg-navy);
    letter-spacing: -0.02em;
  }

