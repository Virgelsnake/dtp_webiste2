  <!-- Hero -->
  <section class="hs-hero">
    <div class="hs-hero-topo"></div>
    <div class="hs-container hs-hero-split">
      <div class="hs-hero-left">
        <span class="hs-overline">Aberdeen-based AI consultancy</span>
