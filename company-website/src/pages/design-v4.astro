            <ellipse cx="200" cy="200" rx="120" ry="120" fill="none" stroke="url(#hs-topo-grad)" stroke-width="1"/>
            <ellipse cx="210" cy="190" rx="90" ry="85" fill="none" stroke="url(#hs-topo-grad)" stroke-width="1"/>
            <ellipse cx="215" cy="185" rx="60" ry="55" fill="none" stroke="url(#hs-topo-grad)" stroke-width="1.5"/>
            <ellipse cx="220" cy="180" rx="30" ry="28" fill="none" stroke="url(#hs-topo-grad)" stroke-width="2"/>
            <circle cx="222" cy="178" r="4" fill="#4ECDC4" opacity="0.8"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="hs-section hs-section-light" id="benefits">
    <div class="hs-container">
      <h2 class="hs-section-title">Why organisations work with us</h2>
      <div class="hs-benefits">
        <div class="hs-benefit">
          <div class="hs-benefit-border"></div>
          <h3>Reduced Risk</h3>
          <p>We deliver in stages. You see progress early and avoid big-bang surprises.</p>
        </div>
        <div class="hs-benefit">
          <div class="hs-benefit-border"></div>
          <h3>Security by Design</h3>
          <p>Data protection and access controls are built in from day one.</p>
        </div>
        <div class="hs-benefit">
          <div class="hs-benefit-border"></div>
          <h3>Reliable Delivery</h3>
          <p>Clear scope, fixed steps, and regular check-ins keep work on track.</p>
        </div>
        <div class="hs-benefit">
          <div class="hs-benefit-border"></div>
          <h3>Scales with You</h3>
          <p>Start small, prove value, then roll out without rework.</p>
        </div>
        <div class="hs-benefit">
          <div class="hs-benefit-border"></div>
          <h3>Flexible Engagement</h3>
          <p>On your stack, in our cloud, or a hybrid — whatever fits.</p>
        </div>
        <div class="hs-benefit">
          <div class="hs-benefit-border"></div>
          <h3>Works With Your Tools</h3>
          <p>We integrate with meeting, messaging, and project platforms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="hs-section hs-section-dark">
    <div class="hs-container hs-testimonial">
      <div class="hs-testi-accent"></div>
      <blockquote>"DTP understood our problem within the first meeting. The staged approach meant we could prove value to the board before committing to a full rollout."</blockquote>
      <cite>— Operations Director, Manufacturing</cite>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="hs-section hs-section-light" id="approach">
    <div class="hs-container">
      <h2 class="hs-section-title">What we're asked to fix most often</h2>
      <div class="hs-use-grid">
        <div class="hs-use-card">
          <div class="hs-use-accent"></div>
          <span class="hs-use-num">01</span>
          <h3>Operations Automation</h3>
          <p>Remove manual steps, reduce errors, and speed up routine work with intelligent process automation.</p>
        </div>
        <div class="hs-use-card">
          <div class="hs-use-accent"></div>
          <span class="hs-use-num">02</span>
          <h3>Data &amp; Reporting</h3>
          <p>Bring data together and give teams clear dashboards, alerts, and actionable insights.</p>
        </div>
        <div class="hs-use-card">
          <div class="hs-use-accent"></div>
          <span class="hs-use-num">03</span>
          <h3>AI Assistants for Teams</h3>
          <p>Turn meetings and messages into organised tasks, updates, and automated workflows.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="hs-section hs-section-dark" id="process">
    <div class="hs-container">
      <h2 class="hs-section-title hs-title-light">Our 5-stage development process</h2>
      <div class="hs-process">
        <div class="hs-process-track">
          <div class="hs-track-line"></div>
          <div class="hs-track-dot hs-dot-1"></div>
          <div class="hs-track-dot hs-dot-2"></div>
          <div class="hs-track-dot hs-dot-3"></div>
          <div class="hs-track-dot hs-dot-4"></div>
          <div class="hs-track-dot hs-dot-5"></div>
        </div>
        <div class="hs-process-steps">
          <div class="hs-pstep"><h3>Discovery</h3><p>Understand your challenge, map processes, identify highest-value opportunity.</p></div>
          <div class="hs-pstep"><h3>Proof of Concept</h3><p>Build a focused prototype to validate approach and demonstrate feasibility.</p></div>
          <div class="hs-pstep"><h3>MVP</h3><p>Develop a working product with core features ready for real-world testing.</p></div>
          <div class="hs-pstep"><h3>Pilot</h3><p>Deploy with a controlled group, gather feedback, refine before wider rollout.</p></div>
          <div class="hs-pstep"><h3>Full Launch</h3><p>Scale to production with monitoring, support, and continuous improvement.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="hs-section hs-section-light" id="work">
    <div class="hs-container">
      <h2 class="hs-section-title">Recent work</h2>
      <div class="hs-cases">
        <div class="hs-case">
          <div class="hs-case-top">
            <span class="hs-case-tag">Manufacturing</span>
            <span class="hs-case-metric">Hours → Minutes</span>
          </div>
          <h3>Automating Surface Area Calculations for Protective Coatings</h3>
          <p>Transformed hours of manual PDF analysis into minutes with 100% calculation accuracy. OCR-enabled tagging interface with automated Excel report generation.</p>
          <div class="hs-case-stack">
            <span>Python</span><span>Flask</span><span>React</span><span>MongoDB</span><span>OCR</span>
          </div>
        </div>
        <div class="hs-case">
          <div class="hs-case-top">
            <span class="hs-case-tag">Manufacturing</span>
            <span class="hs-case-metric">Zero Missed Tasks</span>
          </div>
          <h3>Intelligent Maintenance Management via Mobile Messaging</h3>
          <p>Messaging-native AI agent for production floor engineers. NLP, voice notes, and photo capture — no training required.</p>
          <div class="hs-case-stack">
            <span>AI Agent</span><span>NLP</span><span>Cloud APIs</span><span>Mobile</span>
          </div>
        </div>
        <div class="hs-case">
          <div class="hs-case-top">
            <span class="hs-case-tag">Infrastructure</span>
            <span class="hs-case-metric">Accelerated Delivery</span>
          </div>
          <h3>AI/ML Expertise as Technical Subcontractor</h3>
          <p>Delivered vector database architecture, ML pipelines, and conversational AI within a consultancy's infrastructure monitoring project.</p>
          <div class="hs-case-stack">
            <span>Vector DB</span><span>ML</span><span>Gen AI</span><span>NLP</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="hs-section hs-section-dark" id="faq">
    <div class="hs-container hs-faq-wrap">
      <h2 class="hs-section-title hs-title-light">Common questions</h2>
      <div class="hs-faq-list">
        <details class="hs-faq-item">
          <summary>How long does a typical engagement take?</summary>
          <p>Discovery takes 1–2 weeks. A PoC typically follows in 4–6 weeks. Our staged approach means you see results early.</p>
        </details>
        <details class="hs-faq-item">
          <summary>Do you work with existing systems?</summary>
          <p>Yes. We're stack-agnostic and integrate with your current tools, platforms, and data sources.</p>
        </details>
        <details class="hs-faq-item">
          <summary>What industries do you work with?</summary>
          <p>Manufacturing, infrastructure, energy, and professional services. Our process applies across sectors.</p>
        </details>
        <details class="hs-faq-item">
          <summary>How is pricing structured?</summary>
          <p>Each stage is priced independently. No big-bang contracts — you stay in control throughout.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hs-cta" id="contact">
    <div class="hs-container hs-cta-inner">
      <h2>Ready to see what AI can do for your business?</h2>
      <p>Book a free discovery call. We'll listen, assess fit, and outline next steps — no obligation.</p>
      <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="hs-btn hs-btn-orange hs-btn-lg">Book a Discovery Call</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="hs-footer">
    <div class="hs-container hs-footer-inner">
      <p>&copy; 2025 Digital Technology Partner. All Rights Reserved.</p>
      <div class="hs-footer-links">
        <a href="https://www.linkedin.com/company/dtp-ai/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:Info@digitaltechnologypartner.ai">Email</a>
        <a href="https://wa.me/447769386204">WhatsApp</a>
      </div>
    </div>
  </footer>

  <!-- Variant Badge -->
  <div class="hs-variant-badge">
    V4: Highland Signal
    <a href="/design-v3">← Prev</a>
    <a href="/design-v5">Next →</a>
  </div>
</body>
</html>

<style is:global>
  /* ========== V4: HIGHLAND SIGNAL ========== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --hs-slate: #1B2430;
    --hs-slate-light: #2C3E50;
    --hs-teal: #4ECDC4;
    --hs-teal-dim: rgba(78, 205, 196, 0.12);
    --hs-orange: #FF6B35;
    --hs-orange-dim: rgba(255, 107, 53, 0.1);
    --hs-stone: #F7F7F2;
    --hs-stone-dark: #E8E8E0;
    --hs-text: #1B2430;
    --hs-text-dim: #5A6B7D;
    --hs-white: #FFFFFF;
    --hs-font-display: 'Sora', system-ui, sans-serif;
    --hs-font-body: 'Nunito Sans', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  .hs-body {
    font-family: var(--hs-font-body);
    color: var(--hs-text);
    background: var(--hs-stone);
    line-height: 1.65;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  .hs-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  /* --- NAV --- */
  .hs-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(27, 36, 48, 0.95);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(78, 205, 196, 0.15);
  }

  .hs-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .hs-logo {
    font-family: var(--hs-font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--hs-white);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .hs-logo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--hs-teal);
    display: inline-block;
  }

  .hs-nav-links { display: flex; gap: 2rem; }

  .hs-nav-links a {
    font-size: 0.88rem;
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .hs-nav-links a:hover { color: var(--hs-teal); }

  .hs-nav-cta { font-size: 0.82rem !important; padding: 0.45rem 1.1rem !important; }

  /* --- BUTTONS --- */
  .hs-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--hs-font-display);
    font-weight: 600;
    font-size: 0.92rem;
    padding: 0.8rem 1.6rem;
    border-radius: 10px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 250ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hs-btn-orange {
    background: var(--hs-orange);
    color: white;
    box-shadow: 0 2px 8px rgba(255, 107, 53, 0.25);
  }

  .hs-btn-orange:hover {
    background: #e85d2d;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(255, 107, 53, 0.35);
  }

  .hs-btn-ghost {
    background: transparent;
    color: var(--hs-white);
    border: 1.5px solid rgba(255,255,255,0.25);
  }

  .hs-btn-ghost:hover {
    border-color: var(--hs-teal);
    color: var(--hs-teal);
  }

  .hs-btn-lg { font-size: 1rem; padding: 0.95rem 2rem; }

  /* --- HERO --- */
  .hs-hero {
    position: relative;
    padding: 10rem 0 6rem;
    background: var(--hs-slate);
    overflow: hidden;
  }

  .hs-hero-topo {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg width='600' height='600' viewBox='0 0 600 600' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%234ECDC4' stroke-width='1'%3E%3Cellipse cx='300' cy='300' rx='280' ry='260'/%3E%3Cellipse cx='310' cy='290' rx='220' ry='210'/%3E%3Cellipse cx='315' cy='285' rx='170' ry='155'/%3E%3Cellipse cx='320' cy='280' rx='120' ry='105'/%3E%3Cellipse cx='325' cy='275' rx='70' ry='60'/%3E%3Cellipse cx='328' cy='272' rx='25' ry='22'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 600px;
    background-position: center;
  }

  .hs-hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hs-overline {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--hs-teal);
    margin-bottom: 1.25rem;
  }

  .hs-hero h1 {
    font-family: var(--hs-font-display);
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--hs-white);
    margin-bottom: 1.5rem;
  }

  .hs-hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.65);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .hs-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hs-hero-right { display: flex; justify-content: center; align-items: center; }

  .hs-hero-visual { width: 320px; height: 320px; animation: hs-rotate 30s linear infinite; }

  .hs-topo-svg { width: 100%; height: 100%; }

  @keyframes hs-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* --- SECTIONS --- */
  .hs-section { padding: 6rem 0; }
  .hs-section-light { background: var(--hs-stone); }
  .hs-section-dark { background: var(--hs-slate); }

  .hs-section-title {
    font-family: var(--hs-font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 3.5rem;
    color: var(--hs-text);
  }

  .hs-title-light { color: var(--hs-white); }

  /* --- BENEFITS --- */
  .hs-benefits {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .hs-benefit {
    background: var(--hs-white);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid var(--hs-stone-dark);
  }

  .hs-benefit:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(27, 36, 48, 0.1);
    border-color: var(--hs-teal);
  }

  .hs-benefit-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--hs-teal), transparent);
    opacity: 0;
    transition: opacity 250ms ease;
  }

  .hs-benefit:hover .hs-benefit-border { opacity: 1; }

  .hs-benefit h3 {
    font-family: var(--hs-font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--hs-text);
  }

  .hs-benefit p { color: var(--hs-text-dim); font-size: 0.92rem; }

  /* --- TESTIMONIAL --- */
  .hs-testimonial {
    max-width: 720px;
    text-align: center;
    padding: 2rem 0;
    position: relative;
  }

  .hs-testi-accent {
    width: 48px;
    height: 3px;
    background: var(--hs-teal);
    margin: 0 auto 2rem;
  }

  .hs-testimonial blockquote {
    font-family: var(--hs-font-display);
    font-size: 1.35rem;
    line-height: 1.5;
    color: var(--hs-white);
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .hs-testimonial cite {
    font-style: normal;
    color: var(--hs-teal);
    font-size: 0.88rem;
  }

  /* --- USE CASES --- */
  .hs-use-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .hs-use-card {
    background: var(--hs-white);
    border: 1px solid var(--hs-stone-dark);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hs-use-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(27, 36, 48, 0.1);
    border-color: var(--hs-orange);
  }

  .hs-use-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--hs-orange), transparent);
    opacity: 0;
    transition: opacity 250ms ease;
  }

  .hs-use-card:hover .hs-use-accent { opacity: 1; }

  .hs-use-num {
    font-family: var(--hs-font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--hs-teal);
    opacity: 0.2;
    margin-bottom: 0.75rem;
    display: block;
  }

  .hs-use-card h3 {
    font-family: var(--hs-font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .hs-use-card p { color: var(--hs-text-dim); font-size: 0.92rem; }

  /* --- PROCESS --- */
  .hs-process { margin-top: 0; }

  .hs-process-track {
    position: relative;
    height: 48px;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 10%;
  }

  .hs-track-line {
    position: absolute;
    top: 50%;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg, var(--hs-teal), var(--hs-orange));
    transform: translateY(-50%);
  }

  .hs-track-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--hs-teal);
    position: relative;
    z-index: 2;
    transition: transform 200ms ease;
    box-shadow: 0 0 0 4px rgba(78, 205, 196, 0.2);
  }

