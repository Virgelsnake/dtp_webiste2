---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import DevelopmentJourney from '../../components/DevelopmentJourney.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<Layout title="Services - Digital Technology Partner">
  <div class="bg-gray-900 text-white">
    <Header />
    <main class="relative">
      <div class="pt-24 sm:pt-32">
        <div class="container mx-auto px-6 text-center mb-8">
          <h1 class="text-4xl font-bold tracking-tight sm:text-6xl mb-6">
            Bespoke Digital Solutions
          </h1>
          <p class="text-lg leading-8 text-gray-300 max-w-3xl mx-auto">
            Our development process follows a structured sequence designed to reduce risk and ensure reliable results. We begin by analysing your requirements and existing processes.
          </p>
        </div>
      </div>
      
      <DevelopmentJourney variant="detailed" />
      
      <section class="py-20 sm:py-32 bg-gray-900">
        <div class="container mx-auto px-6">
          <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mb-6">
              Why Choose Our Approach?
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
              <div class="group">
                <div class="flex justify-center mb-8">
                  <div class="relative">
                    <!-- Animated outer ring -->
                    <div class="w-24 h-24 rounded-full border-2 border-blue-500/30 group-hover:animate-spin-slow"></div>
                    <!-- Glowing middle ring -->
                    <div class="absolute inset-2 w-20 h-20 rounded-full border border-blue-400/50 group-hover:animate-pulse"></div>
                    <!-- Inner circle with icon -->
                    <div class="absolute inset-4 w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center border border-blue-500/40">
                      <svg class="w-8 h-8 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"/>
                      </svg>
                    </div>
                    <!-- Glowing effect -->
                    <div class="absolute inset-0 w-24 h-24 rounded-full bg-blue-500/10 group-hover:animate-ping"></div>
                  </div>
                </div>
                <h3 class="text-xl font-semibold text-white mb-4 text-center">Risk Reduction</h3>
                <p class="text-gray-300 text-center">Structured validation at each stage minimizes project risk and ensures successful outcomes.</p>
              </div>
              <div class="group">
                <div class="flex justify-center mb-8">
                  <div class="relative">
                    <!-- Animated outer ring -->
                    <div class="w-24 h-24 rounded-full border-2 border-green-500/30 group-hover:animate-spin-slow"></div>
                    <!-- Glowing middle ring -->
                    <div class="absolute inset-2 w-20 h-20 rounded-full border border-green-400/50 group-hover:animate-pulse"></div>
                    <!-- Inner circle with icon -->
                    <div class="absolute inset-4 w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center border border-green-500/40">
                      <svg class="w-8 h-8 text-green-400" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12,2L13.09,8.26L22,9L13.09,9.74L12,16L10.91,9.74L2,9L10.91,8.26L12,2Z"/>
                      </svg>
                    </div>
                    <!-- Glowing effect -->
                    <div class="absolute inset-0 w-24 h-24 rounded-full bg-green-500/10 group-hover:animate-ping"></div>
                  </div>
                </div>
                <h3 class="text-xl font-semibold text-white mb-4 text-center">Proven Results</h3>
                <p class="text-gray-300 text-center">Our methodology has been refined through numerous successful implementations across industries.</p>
              </div>
              <div class="group">
                <div class="flex justify-center mb-8">
                  <div class="relative">
                    <!-- Animated outer ring -->
                    <div class="w-24 h-24 rounded-full border-2 border-purple-500/30 group-hover:animate-spin-slow"></div>
                    <!-- Glowing middle ring -->
                    <div class="absolute inset-2 w-20 h-20 rounded-full border border-purple-400/50 group-hover:animate-pulse"></div>
                    <!-- Inner circle with icon -->
                    <div class="absolute inset-4 w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center border border-purple-500/40">
                      <svg class="w-8 h-8 text-purple-400" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M16,4C18.2,4 20,5.8 20,8S18.2,12 16,12 12,10.2 12,8 13.8,4 16,4M16,14C20.4,14 24,15.8 24,18V20H8V18C8,15.8 11.6,14 16,14M8.5,4C10.4,4 12,5.6 12,7.5S10.4,11 8.5,11 5,9.4 5,7.5 6.6,4 8.5,4M8.5,13C12.1,13 15,14.3 15,16V18H2V16C2,14.3 4.9,13 8.5,13Z"/>
                      </svg>
                    </div>
                    <!-- Glowing effect -->
                    <div class="absolute inset-0 w-24 h-24 rounded-full bg-purple-500/10 group-hover:animate-ping"></div>
                  </div>
                </div>
                <h3 class="text-xl font-semibold text-white mb-4 text-center">Stakeholder Alignment</h3>
                <p class="text-gray-300 text-center">Direct collaboration with stakeholders ensures solutions meet real business needs.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <CTABanner />
    </main>
  </div>
</Layout>
