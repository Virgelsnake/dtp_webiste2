---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Case Studies - Digital Technology Partner" description="Discover how DTP has helped businesses transform through AI and digital solutions. Real results from our Discovery → PoC → MVP → Pilot → Full Launch process.">
  <div class="relative bg-gray-900 text-white">
    <Header />
    <main class="relative">
      <!-- Hero Section -->
      <div class="pt-24 sm:pt-32 pb-16">
        <div class="container mx-auto px-6 text-center">
          <h1 class="text-4xl font-bold tracking-tight sm:text-6xl">
            Case Studies
          </h1>
          <p class="mt-6 text-lg leading-8 text-gray-300 max-w-3xl mx-auto">
            Real transformations. Real results. See how we've helped businesses across industries turn ideas into successful digital solutions through our proven 5-stage process.
          </p>
        </div>
      </div>

      <!-- Case Studies Grid -->
      <div class="py-16">
        <div class="container mx-auto px-6">
          <div class="grid gap-16 lg:gap-24">
            
            <!-- Case Study 1: Manufacturing AI Optimization -->
            <div class="case-study-card">
              <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div class="order-2 lg:order-1">
                  <div class="case-study-badge">Manufacturing</div>
                  <h2 class="text-3xl font-bold mt-4 mb-6">AI-Powered Production Optimization</h2>
                  <p class="text-gray-300 text-lg mb-6">
                    A leading UK manufacturer was losing £50K monthly due to production inefficiencies and equipment downtime. Traditional monitoring systems provided data but no actionable insights.
                  </p>
                  
                  <div class="results-grid">
                    <div class="result-item">
                      <div class="result-number">40%</div>
                      <div class="result-label">Reduction in Downtime</div>
                    </div>
                    <div class="result-item">
                      <div class="result-number">£180K</div>
                      <div class="result-label">Annual Savings</div>
                    </div>
                    <div class="result-item">
                      <div class="result-number">3 Months</div>
                      <div class="result-label">ROI Achieved</div>
                    </div>
                  </div>

                  <div class="process-timeline">
                    <h3 class="text-xl font-semibold mb-4">Our Process</h3>
                    <div class="timeline-steps">
                      <div class="timeline-step">
                        <div class="step-number">1</div>
                        <div class="step-content">
                          <strong>Discovery:</strong> Mapped production workflows and identified 12 critical bottlenecks
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">2</div>
                        <div class="step-content">
                          <strong>PoC:</strong> Built predictive model for main production line in 2 weeks
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">3</div>
                        <div class="step-content">
                          <strong>MVP:</strong> Deployed real-time monitoring dashboard with AI alerts
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">4</div>
                        <div class="step-content">
                          <strong>Pilot:</strong> Tested across 3 production lines for 6 weeks
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">5</div>
                        <div class="step-content">
                          <strong>Launch:</strong> Full deployment with staff training and support
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="order-1 lg:order-2">
                  <div class="case-study-image">
                    <div class="image-placeholder manufacturing">
                      <div class="placeholder-content">
                        <div class="placeholder-icon">🏭</div>
                        <div class="placeholder-text">Manufacturing Dashboard</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Case Study 2: Healthcare Data Analytics -->
            <div class="case-study-card">
              <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div class="order-1">
                  <div class="case-study-image">
                    <div class="image-placeholder healthcare">
                      <div class="placeholder-content">
                        <div class="placeholder-icon">🏥</div>
                        <div class="placeholder-text">Patient Analytics Platform</div>
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="order-2">
                  <div class="case-study-badge">Healthcare</div>
                  <h2 class="text-3xl font-bold mt-4 mb-6">Patient Flow Analytics System</h2>
                  <p class="text-gray-300 text-lg mb-6">
                    A regional hospital network struggled with patient flow management, leading to overcrowding in A&E and delayed treatments. Manual processes created bottlenecks and poor patient experience.
                  </p>
                  
                  <div class="results-grid">
                    <div class="result-item">
                      <div class="result-number">35%</div>
                      <div class="result-label">Faster Patient Processing</div>
                    </div>
                    <div class="result-item">
                      <div class="result-number">60%</div>
                      <div class="result-label">Reduction in Wait Times</div>
                    </div>
                    <div class="result-item">
                      <div class="result-number">95%</div>
                      <div class="result-label">Staff Satisfaction</div>
                    </div>
                  </div>

                  <div class="process-timeline">
                    <h3 class="text-xl font-semibold mb-4">Our Process</h3>
                    <div class="timeline-steps">
                      <div class="timeline-step">
                        <div class="step-number">1</div>
                        <div class="step-content">
                          <strong>Discovery:</strong> Analyzed patient journey across 4 departments
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">2</div>
                        <div class="step-content">
                          <strong>PoC:</strong> Created predictive model for A&E demand patterns
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">3</div>
                        <div class="step-content">
                          <strong>MVP:</strong> Built real-time dashboard for bed management
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">4</div>
                        <div class="step-content">
                          <strong>Pilot:</strong> Tested in main hospital for 8 weeks
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">5</div>
                        <div class="step-content">
                          <strong>Launch:</strong> Rolled out across entire hospital network
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Case Study 3: Retail Customer Intelligence -->
            <div class="case-study-card">
              <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div class="order-2 lg:order-1">
                  <div class="case-study-badge">Retail</div>
                  <h2 class="text-3xl font-bold mt-4 mb-6">AI-Driven Customer Intelligence Platform</h2>
                  <p class="text-gray-300 text-lg mb-6">
                    A multi-channel retailer with 50+ stores was struggling with inventory management and personalized customer experiences. Disconnected systems meant missed opportunities and excess stock.
                  </p>
                  
                  <div class="results-grid">
                    <div class="result-item">
                      <div class="result-number">25%</div>
                      <div class="result-label">Increase in Sales</div>
                    </div>
                    <div class="result-item">
                      <div class="result-number">45%</div>
                      <div class="result-label">Reduction in Stock Waste</div>
                    </div>
                    <div class="result-item">
                      <div class="result-number">80%</div>
                      <div class="result-label">Improvement in Customer Satisfaction</div>
                    </div>
                  </div>

                  <div class="process-timeline">
                    <h3 class="text-xl font-semibold mb-4">Our Process</h3>
                    <div class="timeline-steps">
                      <div class="timeline-step">
                        <div class="step-number">1</div>
                        <div class="step-content">
                          <strong>Discovery:</strong> Mapped customer journey across online and offline channels
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">2</div>
                        <div class="step-content">
                          <strong>PoC:</strong> Built recommendation engine for top-selling categories
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">3</div>
                        <div class="step-content">
                          <strong>MVP:</strong> Integrated customer data platform with inventory system
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">4</div>
                        <div class="step-content">
                          <strong>Pilot:</strong> Tested in 5 flagship stores for 10 weeks
                        </div>
                      </div>
                      <div class="timeline-step">
                        <div class="step-number">5</div>
                        <div class="step-content">
                          <strong>Launch:</strong> Full rollout with staff training and ongoing support
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="order-1 lg:order-2">
                  <div class="case-study-image">
                    <div class="image-placeholder retail">
                      <div class="placeholder-content">
                        <div class="placeholder-icon">🛍️</div>
                        <div class="placeholder-text">Customer Intelligence Dashboard</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="py-16 bg-gray-800/50">
        <div class="container mx-auto px-6 text-center">
          <h2 class="text-3xl font-bold mb-6">Ready to Transform Your Business?</h2>
          <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
            See how our proven 5-stage process can deliver real results for your organization.
          </p>
          <div class="flex items-center justify-center gap-x-6">
            <a href="/contact" class="get-demo-btn rounded-md bg-blue-600 px-4 py-3 text-sm font-semibold shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 relative overflow-hidden transition-all duration-250 ease-out">
              <span class="relative z-10">Book a Discovery Call</span>
            </a>
            <a href="/services" class="get-started-btn rounded-md bg-gray-800 border border-gray-600 px-3.5 py-2.5 text-sm font-semibold shadow-sm hover:bg-gray-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-600 relative overflow-hidden transition-all duration-250 ease-out">
              <span class="relative z-10">Learn About Our Process <span aria-hidden="true" class="inline-block transition-transform duration-250 ease-out">→</span></span>
            </a>
          </div>
        </div>
      </div>

    </main>
  </div>
</Layout>

<style>
  /* Case Study Styling */
  .case-study-card {
    @apply bg-gray-800/30 backdrop-blur-sm rounded-2xl p-8 lg:p-12 border border-gray-700/50;
    transition: all 300ms ease-out;
  }

  .case-study-card:hover {
    @apply bg-gray-800/50 border-gray-600/50;
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .case-study-badge {
    @apply inline-block px-4 py-2 bg-blue-600/20 text-blue-300 rounded-full text-sm font-semibold border border-blue-500/30;
  }

  .case-study-image {
    @apply relative;
  }

  .image-placeholder {
    @apply w-full h-80 rounded-xl flex items-center justify-center text-center;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(147, 197, 253, 0.05));
    border: 2px dashed rgba(59, 130, 246, 0.3);
  }

  .image-placeholder.manufacturing {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.1), rgba(74, 222, 128, 0.05));
    border-color: rgba(34, 197, 94, 0.3);
  }

  .image-placeholder.healthcare {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(248, 113, 113, 0.05));
    border-color: rgba(239, 68, 68, 0.3);
  }

  .image-placeholder.retail {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.1), rgba(196, 181, 253, 0.05));
    border-color: rgba(168, 85, 247, 0.3);
  }

  .placeholder-content {
    @apply text-center;
  }

  .placeholder-icon {
    @apply text-6xl mb-4;
  }

  .placeholder-text {
    @apply text-gray-400 font-medium;
  }

  .results-grid {
    @apply grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8;
  }

  .result-item {
    @apply text-center p-4 bg-gray-700/30 rounded-lg border border-gray-600/30;
  }

  .result-number {
    @apply text-2xl font-bold text-blue-400 mb-1;
  }

  .result-label {
    @apply text-sm text-gray-300;
  }

  .process-timeline {
    @apply mt-8;
  }

  .timeline-steps {
    @apply space-y-4;
  }

  .timeline-step {
    @apply flex items-start gap-4;
  }

  .step-number {
    @apply flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-semibold;
  }

  .step-content {
    @apply text-gray-300 pt-1;
  }

  /* Enhanced hover effects matching homepage */
  .get-demo-btn {
    position: relative !important;
    transition: all 250ms cubic-bezier(0.4, 0, 0.2, 1) !important;
    overflow: hidden !important;
  }

  .get-demo-btn::before {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 0;
    opacity: 0;
    background: linear-gradient(45deg, rgba(59, 130, 246, 0.2), rgba(147, 197, 253, 0.2));
    transition: opacity 150ms ease-in-out, transform 400ms ease-in-out;
    border-radius: 6px;
    transform: scale(0.8);
  }

  .get-demo-btn:hover {
    color: #ffffff !important;
    background-color: rgba(59, 130, 246, 0.9) !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 12px 30px rgba(59, 130, 246, 0.4), 0 6px 16px rgba(0, 0, 0, 0.2) !important;
  }

  .get-demo-btn:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .get-started-btn {
    position: relative !important;
    padding: 0.625rem 1.25rem !important;
    border-radius: 6px !important;
    transition: all 250ms cubic-bezier(0.4, 0, 0.2, 1) !important;
    overflow: hidden !important;
  }

  .get-started-btn::before {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 0;
    opacity: 0;
    background: linear-gradient(45deg, rgba(255, 255, 255, 0.08), rgba(147, 197, 253, 0.12));
    transition: opacity 150ms ease-in-out, transform 400ms ease-in-out;
    border-radius: 6px;
    transform: scale(0.8);
  }

  .get-started-btn:hover {
    color: #93c5fd !important;
    background-color: rgba(255, 255, 255, 0.08) !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 20px rgba(147, 197, 253, 0.2) !important;
  }

  .get-started-btn:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .get-started-btn:hover span {
    transform: translateX(6px) !important;
  }

  /* Ensure text stays above background effects */
  .get-demo-btn span,
  .get-started-btn {
    position: relative;
    z-index: 10;
  }

  /* Arrow animation */
  .get-started-btn span[aria-hidden="true"] {
    display: inline-block;
    transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1) !important;
  }
</style>
