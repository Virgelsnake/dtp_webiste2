---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Case Studies - Digital Technology Partner" description="Discover how DTP has helped businesses transform through AI and digital solutions. Real results from our Discovery → PoC → MVP → Pilot → Full Launch process.">
  <Header />
  <main>
    <!-- Hero -->
    <section class="ma-hero">
      <div class="ma-grid-bg"></div>
      <div class="ma-scan-line"></div>
      <div class="ma-container ma-hero-content">
        <div class="ma-hero-tag">// case_studies</div>
        <h1>Case Studies<span class="ma-cursor">|</span></h1>
        <p class="ma-hero-sub">Real transformations. Real results. See how we've helped businesses across industries turn ideas into successful digital solutions through our proven development process.</p>
      </div>
    </section>

    <!-- Case Studies -->
    <section class="ma-section">
      <div class="ma-container">
        <div class="cs-list">

          <!-- Case Study 1: Protective Coating Automation -->
          <article class="cs-card">
            <div class="cs-header">
              <span class="ma-tag">Manufacturing</span>
              <h2>Automating Surface Area Calculations for Protective Coating Applications</h2>
              <p>A specialist protective coating company was spending significant time manually analyzing PDF engineering drawings to calculate surface areas for quotations. This manual process was time-consuming and error-prone, creating bottlenecks in their competitive quotation process.</p>
            </div>

            <div class="cs-grid">
              <div class="cs-col">
                <h3>The Challenge</h3>
                <ul>
                  <li>Manual identification of fabricated structures from PDF drawings</li>
                  <li>Complex mathematical calculations for various geometric shapes</li>
                  <li>Time-consuming quotation process affecting competitiveness</li>
                  <li>Risk of human error in critical pricing calculations</li>
                </ul>
              </div>
              <div class="cs-col">
                <h3>Our Solution</h3>
                <div class="cs-solutions">
                  <div class="cs-solution-item"><strong>Interactive PDF Processing</strong><p>OCR-enabled tagging interface for direct element selection</p></div>
                  <div class="cs-solution-item"><strong>Automated Calculations</strong><p>Pre-defined formulas for CHS/SHS, I-Beams, RSA, and more</p></div>
                  <div class="cs-solution-item"><strong>Multi-tenant Architecture</strong><p>MongoDB backend with React frontend for secure data management</p></div>
                  <div class="cs-solution-item"><strong>Export Integration</strong><p>Automated Excel report generation for quotation workflow</p></div>
                </div>
              </div>
            </div>

            <div class="cs-impact">
              <h3>Business Impact</h3>
              <div class="cs-impact-grid">
                <div class="cs-impact-item"><div class="cs-impact-val">Hours → Minutes</div><div class="cs-impact-label">Processing Time Reduction</div></div>
                <div class="cs-impact-item"><div class="cs-impact-val">100%</div><div class="cs-impact-label">Calculation Accuracy</div></div>
                <div class="cs-impact-item"><div class="cs-impact-val">Faster</div><div class="cs-impact-label">Quote Turnaround</div></div>
              </div>
            </div>

            <div class="cs-tech">
              <h4>Technology Stack</h4>
              <div class="cs-tech-tags"><span class="ma-tag">Python</span><span class="ma-tag">Flask/FastAPI</span><span class="ma-tag">React</span><span class="ma-tag">MongoDB</span><span class="ma-tag">OCR</span></div>
            </div>
          </article>

          <!-- Case Study 2: Manufacturing Maintenance AI -->
          <article class="cs-card">
            <div class="cs-header">
              <span class="ma-tag">Manufacturing</span>
              <h2>Transforming Manufacturing Maintenance Through Intelligent Messaging</h2>
              <p>A window and door manufacturer needed to systematically manage machine maintenance across their production floor. Engineers worked directly with machinery and rarely accessed desktop systems, creating a communication gap for critical maintenance tasks.</p>
            </div>

            <div class="cs-grid">
              <div class="cs-col">
                <h3>The Challenge</h3>
                <ul>
                  <li>No systematic reminders for scheduled maintenance</li>
                  <li>Engineers worked on production floor, not at computers</li>
                  <li>Missed maintenance windows causing potential equipment failures</li>
                  <li>Lack of management visibility on maintenance completion</li>
                </ul>
              </div>
              <div class="cs-col">
                <h3>Our Solution</h3>
                <div class="cs-solutions">
                  <div class="cs-solution-item"><strong>Messaging-Native Interface</strong><p>AI agent integrated with existing mobile messaging platforms</p></div>
                  <div class="cs-solution-item"><strong>Natural Language Processing</strong><p>Text, voice-to-text, and voice note processing capabilities</p></div>
                  <div class="cs-solution-item"><strong>Visual Documentation</strong><p>Mobile camera integration for maintenance evidence capture</p></div>
                  <div class="cs-solution-item"><strong>Meeting Integration</strong><p>Automatic task extraction from meeting transcriptions</p></div>
                </div>
              </div>
            </div>

            <div class="cs-impact">
              <h3>Business Impact</h3>
              <div class="cs-impact-grid">
                <div class="cs-impact-item"><div class="cs-impact-val">Zero</div><div class="cs-impact-label">Missed Maintenance</div></div>
                <div class="cs-impact-item"><div class="cs-impact-val">Real-time</div><div class="cs-impact-label">Management Visibility</div></div>
                <div class="cs-impact-item"><div class="cs-impact-val">No Training</div><div class="cs-impact-label">Required for Engineers</div></div>
              </div>
            </div>

            <div class="cs-tech">
              <h4>Technology Stack</h4>
              <div class="cs-tech-tags"><span class="ma-tag">AI Agent</span><span class="ma-tag">NLP</span><span class="ma-tag">Cloud APIs</span><span class="ma-tag">Mobile Integration</span><span class="ma-tag">Voice Processing</span></div>
            </div>
          </article>

          <!-- Case Study 3: Infrastructure AI Partnership -->
          <article class="cs-card">
            <div class="cs-header">
              <span class="ma-tag">Infrastructure</span>
              <h2>Delivering AI Expertise as Technical Partner in Infrastructure Analytics</h2>
              <p>A specialist technology consultancy needed advanced AI and machine learning expertise for their infrastructure client project. They required a trusted technical partner to deliver production-ready AI solutions while maintaining client relationships.</p>
            </div>

            <div class="cs-grid">
              <div class="cs-col">
                <h3>The Partnership Need</h3>
                <ul>
                  <li>Client required sophisticated root cause analysis capabilities</li>
                  <li>Needed AI-enhanced reporting within existing monitoring platform</li>
                  <li>Consultancy lacked specialized AI/ML expertise</li>
                  <li>Required rapid integration with existing project team</li>
                </ul>
              </div>
              <div class="cs-col">
                <h3>Our Technical Contributions</h3>
                <div class="cs-solutions">
                  <div class="cs-solution-item"><strong>Vector Database Architecture</strong><p>Designed efficient indexing for natural language queries</p></div>
                  <div class="cs-solution-item"><strong>ML Pipeline Development</strong><p>Built classification algorithms for predictive root cause analysis</p></div>
                  <div class="cs-solution-item"><strong>Integration Strategy</strong><p>Seamless data parsing pipelines with existing platform APIs</p></div>
                  <div class="cs-solution-item"><strong>Conversational AI Framework</strong><p>Natural language processing for technical query transformation</p></div>
                </div>
              </div>
            </div>

            <div class="cs-impact">
              <h3>Business Impact</h3>
              <div class="cs-impact-grid">
                <div class="cs-impact-item"><div class="cs-impact-val">Expanded</div><div class="cs-impact-label">Service Capabilities</div></div>
                <div class="cs-impact-item"><div class="cs-impact-val">Accelerated</div><div class="cs-impact-label">Project Delivery</div></div>
                <div class="cs-impact-item"><div class="cs-impact-val">Enhanced</div><div class="cs-impact-label">Client Value</div></div>
              </div>
            </div>

            <div class="cs-partnership">
              <h4>Partnership Model</h4>
              <p>Technical subcontracting that allowed our client to maintain project ownership and client relationships while accessing deep AI/ML expertise when needed.</p>
            </div>

            <div class="cs-tech">
              <h4>Technology Stack</h4>
              <div class="cs-tech-tags"><span class="ma-tag">Vector Databases</span><span class="ma-tag">Machine Learning</span><span class="ma-tag">Generative AI</span><span class="ma-tag">NLP</span><span class="ma-tag">API Integration</span></div>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="ma-cta">
      <div class="ma-container ma-cta-inner">
        <h2>Ready to Transform Your Business?</h2>
        <p>See how our proven 5-stage process can deliver real results for your organisation.</p>
        <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="ma-btn ma-btn-mint ma-btn-lg">Book a Discovery Call</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* --- Hero --- */
  .ma-hero {
    position: relative;
    padding: 11rem 0 6rem;
    overflow: hidden;
  }
  .ma-hero-content { position: relative; z-index: 2; max-width: 720px; }
  .ma-hero-tag {
    font-family: var(--ma-font-mono);
    font-size: 0.85rem;
    color: var(--ma-mint);
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }
  .ma-hero h1 { line-height: 1.05; margin-bottom: 1.5rem; letter-spacing: -0.03em; }
  .ma-hero-sub {
    font-size: 1.1rem;
    color: var(--ma-text-dim);
    max-width: 600px;
    line-height: 1.7;
  }

  /* --- Case Study List --- */
  .cs-list { display: flex; flex-direction: column; gap: 3rem; }

  /* --- Case Study Card --- */
  .cs-card {
    background: var(--ma-surface);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius-lg);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: all 350ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .cs-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ma-mint), transparent);
    opacity: 0;
    transition: opacity 350ms ease;
  }
  .cs-card:hover {
    border-color: var(--ma-mint);
    transform: translateY(-4px);
    box-shadow: 0 0 0 1px var(--ma-mint), 0 24px 48px rgba(0, 229, 160, 0.08);
  }
  .cs-card:hover::before { opacity: 1; }

  /* --- Header --- */
  .cs-header { margin-bottom: 2rem; }
  .cs-header .ma-tag { margin-bottom: 1rem; display: inline-block; }
  .cs-header h2 { font-size: clamp(1.4rem, 3vw, 2rem); margin-bottom: 1rem; }
  .cs-header p { font-size: 0.95rem; color: var(--ma-text-dim); line-height: 1.7; max-width: 700px; }

  /* --- 2-Col Grid --- */
  .cs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; margin-bottom: 2rem; }
  .cs-col h3 {
    font-size: 1.05rem;
    margin-bottom: 1rem;
    color: var(--ma-mint);
    font-weight: 600;
  }
  .cs-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .cs-col li {
    font-size: 0.9rem;
    color: var(--ma-text);
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.6;
  }
  .cs-col li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ma-mint);
    opacity: 0.5;
  }

  /* --- Solution Items --- */
  .cs-solutions { display: flex; flex-direction: column; gap: 0.75rem; }
  .cs-solution-item {
    background: var(--ma-surface-alt);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius);
    padding: 1rem 1.25rem;
    transition: all 250ms ease;
  }
  .cs-solution-item:hover {
    border-color: rgba(0, 229, 160, 0.3);
    transform: translateY(-1px);
  }
  .cs-solution-item strong {
    color: var(--ma-white);
    font-size: 0.92rem;
    font-weight: 600;
    display: block;
    margin-bottom: 0.25rem;
  }
  .cs-solution-item p {
    font-size: 0.82rem;
    color: var(--ma-text-dim);
    line-height: 1.5;
    margin: 0;
  }

  /* --- Impact --- */
  .cs-impact { margin-bottom: 2rem; }
  .cs-impact h3 {
    text-align: center;
    margin-bottom: 1.25rem;
    font-size: 1.05rem;
  }
  .cs-impact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .cs-impact-item {
    text-align: center;
    padding: 1.25rem 1rem;
    background: var(--ma-surface-alt);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius);
    transition: all 250ms ease;
  }
  .cs-impact-item:hover {
    border-color: rgba(0, 229, 160, 0.3);
    transform: translateY(-2px);
  }
  .cs-impact-val {
    font-family: var(--ma-font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: var(--ma-mint);
    margin-bottom: 0.35rem;
  }
  .cs-impact-label {
    font-size: 0.78rem;
    color: var(--ma-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* --- Partnership Callout --- */
  .cs-partnership {
    background: var(--ma-surface-alt);
    border: 1px solid var(--ma-border);
    border-left: 3px solid var(--ma-mint);
    border-radius: var(--ma-radius);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
  }
  .cs-partnership h4 {
    color: var(--ma-mint);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .cs-partnership p {
    font-size: 0.9rem;
    color: var(--ma-text-dim);
    line-height: 1.65;
  }

  /* --- Tech Stack --- */
  .cs-tech h4 {
    font-size: 0.85rem;
    color: var(--ma-text-dim);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .cs-tech-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  /* --- CTA --- */
  .ma-cta {
    padding: 6rem 0;
    background: linear-gradient(135deg, var(--ma-surface) 0%, var(--ma-bg) 100%);
    border-top: 1px solid var(--ma-border);
  }
  .ma-cta-inner { text-align: center; max-width: 600px; }
  .ma-cta-inner h2 { margin-bottom: 1rem; }
  .ma-cta-inner p { color: var(--ma-text-dim); margin-bottom: 2rem; font-size: 1.05rem; }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .ma-hero { padding: 8rem 0 4rem; }
    .cs-card { padding: 1.5rem; }
    .cs-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .cs-impact-grid { grid-template-columns: 1fr; }
  }
</style>
