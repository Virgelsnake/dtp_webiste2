---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
---

<Layout title="Privacy Policy - 10 Touches" description="Privacy Policy for 10 Touches - Your personal CRM app that keeps all data locally on your device.">
  <div class="relative bg-gray-900 text-white min-h-screen">
    <Header />
    
    <main class="relative pt-24 pb-16">
      <div class="container mx-auto px-6 max-w-4xl">
        
        <!-- Hero Header with Animated Rings -->
        <div class="text-center mb-16">
          <div class="relative inline-flex items-center justify-center mb-6">
            <div class="absolute w-24 h-24 rounded-2xl border-2 border-blue-500/30 animate-spin-slow"></div>
            <div class="absolute inset-2 w-20 h-20 rounded-2xl border border-blue-400/50 animate-pulse"></div>
            <div class="relative w-20 h-20 rounded-2xl bg-gradient-to-br from-blue-600 to-blue-800 flex items-center justify-center shadow-lg shadow-blue-500/50 border border-blue-500/40">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"></path>
              </svg>
            </div>
            <div class="absolute inset-0 w-24 h-24 rounded-2xl bg-blue-500/10 animate-ping opacity-75"></div>
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">Privacy Policy</h1>
          <p class="text-xl text-gray-300 mb-2">10 Touches - Personal CRM</p>
          <p class="text-sm text-gray-400">Last Updated: January 13, 2026</p>
        </div>

        <!-- Key Privacy Statement -->
        <div class="mb-12 p-8 rounded-2xl bg-gradient-to-br from-blue-600/20 to-blue-800/20 border border-blue-500/30 backdrop-blur-sm">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold mb-3 text-blue-400">Your Data Stays on Your Device</h2>
              <p class="text-gray-300 text-lg leading-relaxed">
                <strong>All data you enter into 10 Touches is stored locally on your device.</strong> 
                We do not transmit, sync, or store any of your personal information on external servers. 
                Your contacts, notes, and relationship data never leave your iPhone or iPad.
              </p>
            </div>
          </div>
        </div>

        <!-- Overview Section -->
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6">Overview</h2>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed">
              10 Touches is a personal CRM app designed to help you maintain meaningful relationships 
              with your professional network. Your privacy is our top priority.
            </p>
          </div>
        </section>

        <!-- Information Stored Locally -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">Information the App May Store Locally</h2>
          <p class="text-gray-300 mb-6">10 Touches may store the following types of information on your device:</p>
          <div class="grid gap-4">
            <div class="bento-card group">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-blue-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2 text-blue-400">Contact Information</h3>
                  <p class="text-gray-300">Names, email addresses, phone numbers, and company details</p>
                </div>
              </div>
            </div>
            <div class="bento-card group">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-purple-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2 text-purple-400">Personal Context</h3>
                  <p class="text-gray-300">Notes about family members, interests, hobbies, and preferences</p>
                </div>
              </div>
            </div>
            <div class="bento-card group">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-cyan-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2 text-cyan-400">Business Information</h3>
                  <p class="text-gray-300">Job titles, companies, industries, and professional relationships</p>
                </div>
              </div>
            </div>
            <div class="bento-card group">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-green-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2 text-green-400">Interaction History</h3>
                  <p class="text-gray-300">Dates and notes about your communications and meetings</p>
                </div>
              </div>
            </div>
            <div class="bento-card group">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-xl font-semibold mb-2 text-orange-400">Reminders & Settings</h3>
                  <p class="text-gray-300">Touch frequency preferences, notification settings, and app preferences</p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Data We Do NOT Collect -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">Data We Do NOT Collect</h2>
          <div class="p-8 rounded-2xl bg-gradient-to-br from-green-600/20 to-emerald-800/20 border border-green-500/30 backdrop-blur-sm">
            <h3 class="text-2xl font-bold mb-4 text-green-400">✓ Zero Server-Side Data Collection</h3>
            <ul class="space-y-3 text-gray-300">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>We do not collect or transmit any personal information to our servers</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>We do not track your usage or behavior</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>We do not use analytics or tracking tools</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>We do not share your data with third parties</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>We do not sell your information</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>We do not access your device's location</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- Third-Party Services -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">Third-Party Services</h2>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed">
              10 Touches does not integrate with any third-party services, analytics platforms, 
              or advertising networks. The app operates entirely offline and does not require 
              an internet connection to function.
            </p>
          </div>
        </section>

        <!-- Your Rights and Controls -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">Your Rights and Controls</h2>
          <p class="text-gray-300 mb-6">Because all data is stored locally on your device, you have complete control:</p>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bento-card group">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-blue-400">Access</h3>
              </div>
              <p class="text-gray-300">All your data is accessible within the app at any time</p>
            </div>
            <div class="bento-card group">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-blue-400">Modification</h3>
              </div>
              <p class="text-gray-300">You can edit or update any information you've entered</p>
            </div>
            <div class="bento-card group">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-blue-400">Deletion</h3>
              </div>
              <p class="text-gray-300">You can delete individual contacts or all data at any time</p>
            </div>
            <div class="bento-card group">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-blue-400">Complete Removal</h3>
              </div>
              <p class="text-gray-300">Deleting the app removes all associated data from your device</p>
            </div>
          </div>
        </section>

        <!-- iCloud Backup -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">iCloud Backup</h2>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed">
              If you have iCloud backup enabled on your device, your 10 Touches data may be 
              included in your device's encrypted iCloud backup. This is controlled by your 
              device settings, not by the app. Apple's privacy policy governs iCloud backups.
            </p>
          </div>
        </section>

        <!-- Security -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">Security</h2>
          <p class="text-gray-300 mb-6">
            Since all data is stored locally on your device, the security of your information 
            is protected by your device's security features, including:
          </p>
          <div class="grid md:grid-cols-3 gap-4">
            <div class="bento-card group text-center">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"></path>
                </svg>
              </div>
              <h3 class="text-lg font-semibold mb-2 text-blue-400">Biometric Auth</h3>
              <p class="text-gray-300 text-sm">Face ID / Touch ID</p>
            </div>
            <div class="bento-card group text-center">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-semibold mb-2 text-blue-400">iOS Encryption</h3>
              <p class="text-gray-300 text-sm">Device-level security</p>
            </div>
            <div class="bento-card group text-center">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-semibold mb-2 text-blue-400">Physical Security</h3>
              <p class="text-gray-300 text-sm">Your device protection</p>
            </div>
          </div>
          <p class="text-gray-300 mt-6 text-center">
            We recommend keeping your device locked and using strong authentication methods 
            to protect your personal information.
          </p>
        </section>

        <!-- Children's Privacy -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">Children's Privacy</h2>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed">
              10 Touches is not directed to children under 13. We do not knowingly collect 
              information from children. If you are under 13, please do not use this app.
            </p>
          </div>
        </section>

        <!-- Changes to Policy -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">Changes to This Privacy Policy</h2>
          <div class="bento-card">
            <p class="text-gray-300 text-lg leading-relaxed">
              We may update this Privacy Policy from time to time. Any changes will be reflected 
              in the "Last Updated" date at the top of this page. We encourage you to review 
              this policy periodically.
            </p>
          </div>
        </section>

        <!-- Summary Table -->
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">Quick Reference</h2>
          <div class="overflow-hidden rounded-2xl border border-gray-700">
            <table class="w-full">
              <thead>
                <tr class="bg-blue-600">
                  <th class="px-6 py-4 text-left text-white font-semibold">Question</th>
                  <th class="px-6 py-4 text-left text-white font-semibold">Answer</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-700">
                <tr class="bg-gray-800/50 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Where is my data stored?</td>
                  <td class="px-6 py-4 text-blue-400 font-semibold">Locally on your device only</td>
                </tr>
                <tr class="bg-gray-800/30 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Do you send data to servers?</td>
                  <td class="px-6 py-4 text-blue-400 font-semibold">No, never</td>
                </tr>
                <tr class="bg-gray-800/50 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Do you use analytics?</td>
                  <td class="px-6 py-4 text-blue-400 font-semibold">No</td>
                </tr>
                <tr class="bg-gray-800/30 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Do you share data with third parties?</td>
                  <td class="px-6 py-4 text-blue-400 font-semibold">No</td>
                </tr>
                <tr class="bg-gray-800/50 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Can I delete my data?</td>
                  <td class="px-6 py-4 text-blue-400 font-semibold">Yes, at any time</td>
                </tr>
                <tr class="bg-gray-800/30 hover:bg-gray-800 transition-colors">
                  <td class="px-6 py-4 text-gray-300">Does the app require internet?</td>
                  <td class="px-6 py-4 text-blue-400 font-semibold">No, works completely offline</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Contact Section -->
        <div class="mb-12 p-8 rounded-2xl bg-gradient-to-br from-gray-800/50 to-gray-800/30 border border-gray-700 text-center">
          <h2 class="text-3xl font-bold mb-4">Contact Us</h2>
          <p class="text-gray-300 mb-6">If you have questions about this Privacy Policy, please contact us:</p>
