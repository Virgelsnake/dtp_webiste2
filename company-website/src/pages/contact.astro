---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Contact Us - Digital Technology Partner">
  <Header />
  <main>
    <!-- Hero -->
    <section class="ma-hero">
      <div class="ma-grid-bg"></div>
      <div class="ma-scan-line"></div>
      <div class="ma-container ma-hero-content">
        <div class="ma-hero-tag">// contact</div>
        <h1>Get in Touch<span class="ma-cursor">|</span></h1>
        <p class="ma-hero-sub">We'd love to learn about your challenges and explore how AI can drive real transformation for your business.</p>
      </div>
    </section>

    <!-- Contact Details -->
    <section class="ma-section">
      <div class="ma-container">
        <div class="contact-layout">
          <!-- Left: CTA + Map -->
          <div class="contact-left">
            <!-- Book a Call CTA -->
            <div class="ma-card contact-cta-card">
              <div class="ma-card-line"></div>
              <h3>Book a Discovery Call</h3>
              <p>Ready to transform your business with AI? Let's discuss your project and explore how we can help.</p>
              <a href="https://outlook.office.com/bookwithme/user/f0762b9af6a94ed2add9818a4f3ca4e5@digitaltechnologypartner.ai/meetingtype/qc2lOXjEdkO6GkMS_jZJrQ2?anonymous" target="_blank" rel="noopener noreferrer" class="ma-btn ma-btn-mint">Book a Discovery Call</a>
            </div>

            <!-- Map Section -->
            <div class="ma-card contact-map-card">
              <div class="ma-card-line"></div>
              <h3>Find Us</h3>
              <div class="map-placeholder">
                <div class="map-placeholder-inner">
                  <span class="map-icon">&#9906;</span>
                  <p>111 Gallowgate, Aberdeen AB25 1BU</p>
                </div>
              </div>
              <div class="map-links">
                <a href="https://maps.google.com/?q=111+Gallowgate,+Aberdeen+AB25+1BU" target="_blank" rel="noopener noreferrer" class="ma-btn ma-btn-outline map-link-btn">Google Maps →</a>
                <a href="https://www.openstreetmap.org/?mlat=57.1497&mlon=-2.0943#map=16/57.1497/-2.0943" target="_blank" rel="noopener noreferrer" class="ma-btn ma-btn-outline map-link-btn">OpenStreetMap →</a>
              </div>
            </div>
          </div>

          <!-- Right: Address, Contact Methods, Getting Here -->
          <div class="contact-right">
            <!-- Office Address -->
            <div class="ma-card">
              <div class="ma-card-line"></div>
              <span class="ma-section-tag">// our_office</span>
              <h3>Our Office</h3>
              <p class="contact-address">111 Gallowgate<br>Aberdeen<br>AB25 1BU<br>Scotland, United Kingdom</p>
            </div>

            <!-- Contact Methods -->
            <div class="contact-methods">
              <a href="mailto:Info@digitaltechnologypartner.ai" class="ma-card contact-method-card">
                <div class="ma-card-line"></div>
                <h4>Email</h4>
                <span class="contact-method-val">Info@digitaltechnologypartner.ai</span>
              </a>
              <a href="https://wa.me/447769386204" class="ma-card contact-method-card">
                <div class="ma-card-line"></div>
                <h4>WhatsApp</h4>
                <span class="contact-method-val">+44 7769 386204</span>
              </a>
            </div>

            <!-- Getting Here -->
            <div class="ma-card">
              <div class="ma-card-line"></div>
              <h3>Getting Here</h3>
              <div class="getting-here-list">
                <div class="getting-here-item">
                  <h4>By Car</h4>
                  <p>Central Aberdeen location with nearby parking options. A96 and A90 access routes.</p>
                </div>
                <div class="getting-here-item">
                  <h4>Public Transport</h4>
                  <p>Aberdeen Bus Station nearby. Regular services from across Scotland.</p>
                </div>
                <div class="getting-here-item">
                  <h4>By Air</h4>
                  <p>Aberdeen Airport 20 minutes away. Regular flights from major UK cities.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="ma-cta">
      <div class="ma-container ma-cta-inner">
        <h2>Ready to Transform Your Business?</h2>
        <p>Let's discuss how AI solutions can drive growth and efficiency for your business. Get in touch today.</p>
        <div class="cta-actions">
          <a href="mailto:Info@digitaltechnologypartner.ai" class="ma-btn ma-btn-outline">Send Email →</a>
          <a href="https://wa.me/447769386204" class="ma-btn ma-btn-outline">WhatsApp →</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* --- Hero --- */
  .ma-hero {
    position: relative;
    padding: 11rem 0 6rem;
    overflow: hidden;
  }
  .ma-hero-content { position: relative; z-index: 2; max-width: 720px; }
  .ma-hero-tag {
    font-family: var(--ma-font-mono);
    font-size: 0.85rem;
    color: var(--ma-mint);
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }
  .ma-hero h1 { line-height: 1.05; margin-bottom: 1.5rem; letter-spacing: -0.03em; }
  .ma-hero-sub {
    font-size: 1.1rem;
    color: var(--ma-text-dim);
    max-width: 560px;
    line-height: 1.7;
  }

  /* --- Contact Layout --- */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .contact-left, .contact-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* --- CTA Card --- */
  .contact-cta-card { text-align: center; }
  .contact-cta-card h3 { margin-bottom: 0.75rem; }
  .contact-cta-card p { font-size: 0.9rem; margin-bottom: 1.5rem; }

  /* --- Map --- */
  .contact-map-card h3 { margin-bottom: 1rem; }
  .map-placeholder {
    background: var(--ma-surface-alt);
    border: 1px solid var(--ma-border);
    border-radius: var(--ma-radius);
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .map-placeholder-inner { text-align: center; }
  .map-icon { font-size: 2rem; color: var(--ma-mint); display: block; margin-bottom: 0.5rem; }
  .map-placeholder-inner p { font-size: 0.85rem; color: var(--ma-text-dim); }
  .map-links { display: flex; gap: 0.75rem; }
  .map-link-btn { font-size: 0.82rem; padding: 0.5rem 1rem; }

  /* --- Address --- */
  .ma-card h3 { margin-bottom: 0.5rem; }
  .contact-address { font-size: 0.92rem; line-height: 1.8; color: var(--ma-text); }

  /* --- Contact Methods --- */
  .contact-methods { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .contact-method-card {
    display: block;
    text-decoration: none;
  }
  .contact-method-card h4 {
    font-size: 0.85rem;
    color: var(--ma-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.35rem;
  }
  .contact-method-val {
    font-size: 0.85rem;
    color: var(--ma-mint);
    word-break: break-all;
  }

  /* --- Getting Here --- */
  .getting-here-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 0.75rem; }
  .getting-here-item h4 {
    font-size: 0.9rem;
    color: var(--ma-white);
    margin-bottom: 0.2rem;
  }
  .getting-here-item p {
    font-size: 0.82rem;
    color: var(--ma-text-dim);
    line-height: 1.5;
  }

  /* --- CTA --- */
  .ma-cta {
    padding: 6rem 0;
    background: linear-gradient(135deg, var(--ma-surface) 0%, var(--ma-bg) 100%);
    border-top: 1px solid var(--ma-border);
  }
  .ma-cta-inner { text-align: center; max-width: 600px; }
  .ma-cta-inner h2 { margin-bottom: 1rem; }
  .ma-cta-inner p { color: var(--ma-text-dim); margin-bottom: 2rem; font-size: 1.05rem; }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .ma-hero { padding: 8rem 0 4rem; }
    .contact-layout { grid-template-columns: 1fr; }
    .contact-methods { grid-template-columns: 1fr; }
    .map-links { flex-direction: column; }
  }
</style>
