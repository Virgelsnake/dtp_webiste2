---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Thank You - Digital Technology Partner"
  description="Thank you for your message."
>
  <div class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-grow container mx-auto px-4 py-8 text-center">
      <h1 class="text-3xl font-bold text-gray-800 mb-6">Thank You!</h1>
      <p class="text-lg text-gray-600">
        Your message has been sent successfully. We will get back to you
        shortly.
      </p>
      <a
        href="/"
        class="mt-8 inline-block bg-blue-500 text-white py-2 px-4 rounded-md hover:bg-blue-600"
      >
        Return to Home
      </a>
    </main>
    <Footer />
  </div>
</BaseLayout>
