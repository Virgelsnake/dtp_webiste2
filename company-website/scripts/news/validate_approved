#!/usr/bin/env python3
"""
Validate approved newsroom articles have required governance metadata.
"""

from __future__ import annotations

from pathlib import Path
import re
import sys


def field(text: str, name: str) -> str | None:
    m = re.search(rf'^{name}:\s*(.+)$', text, re.MULTILINE)
    return m.group(1).strip() if m else None


def main() -> int:
    news_dir = Path('src/content/news')
    problems: list[str] = []

    for md in sorted(news_dir.glob('*.md')):
        text = md.read_text(encoding='utf-8')
        approved = field(text, 'approved')
        if approved != 'true':
            continue

        for required in ['source', 'approvedBy', 'approvedAt', 'description']:
            if not field(text, required):
                problems.append(f'{md.name}: missing {required}')

    if problems:
        print('Approved article validation FAILED:')
        for p in problems:
            print('-', p)
        return 1

    print('Approved article validation PASSED')
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
